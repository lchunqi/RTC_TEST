 422:Core/Src/bsp_spi_flash.c ****  /**
 423:Core/Src/bsp_spi_flash.c ****   * @brief  ĘąÓĂSPI·˘ËÍŇ»¸ö×Ö˝ÚµÄĘýľÝ
 424:Core/Src/bsp_spi_flash.c ****   * @param  byteŁşŇŞ·˘ËÍµÄĘýľÝ
 425:Core/Src/bsp_spi_flash.c ****   * @retval ·µ»Ř˝ÓĘŐµ˝µÄĘýľÝ
 426:Core/Src/bsp_spi_flash.c ****   */
 427:Core/Src/bsp_spi_flash.c **** uint8_t SPI_FLASH_SendByte(uint8_t byte)
 428:Core/Src/bsp_spi_flash.c **** {
 429:Core/Src/bsp_spi_flash.c ****   SPITimeout = SPIT_FLAG_TIMEOUT;
 430:Core/Src/bsp_spi_flash.c **** 
 431:Core/Src/bsp_spi_flash.c ****   /* µČ´ý·˘ËÍ»şłĺÇřÎŞżŐŁ¬TXEĘÂĽţ */
 432:Core/Src/bsp_spi_flash.c ****   while (__HAL_SPI_GET_FLAG( &SpiHandle, SPI_FLAG_TXE ) == RESET)
 433:Core/Src/bsp_spi_flash.c ****    {
 434:Core/Src/bsp_spi_flash.c ****     if((SPITimeout--) == 0) return SPI_TIMEOUT_UserCallback(0);
 435:Core/Src/bsp_spi_flash.c ****    }
 436:Core/Src/bsp_spi_flash.c **** 
 437:Core/Src/bsp_spi_flash.c ****   /* Đ´ČëĘýľÝĽÄ´ćĆ÷Ł¬°ŃŇŞĐ´ČëµÄĘýľÝĐ´Čë·˘ËÍ»şłĺÇř */
 438:Core/Src/bsp_spi_flash.c ****   WRITE_REG(SpiHandle.Instance->DR, byte);
 439:Core/Src/bsp_spi_flash.c **** 
 440:Core/Src/bsp_spi_flash.c ****   SPITimeout = SPIT_FLAG_TIMEOUT;
 441:Core/Src/bsp_spi_flash.c **** 
 442:Core/Src/bsp_spi_flash.c ****   /* µČ´ý˝ÓĘŐ»şłĺÇř·ÇżŐŁ¬RXNEĘÂĽţ */
 443:Core/Src/bsp_spi_flash.c ****   while (__HAL_SPI_GET_FLAG( &SpiHandle, SPI_FLAG_RXNE ) == RESET)
 444:Core/Src/bsp_spi_flash.c ****    {
 445:Core/Src/bsp_spi_flash.c ****     if((SPITimeout--) == 0) return SPI_TIMEOUT_UserCallback(1);
 446:Core/Src/bsp_spi_flash.c ****    }
 447:Core/Src/bsp_spi_flash.c **** 
 448:Core/Src/bsp_spi_flash.c ****   /* ¶ÁČˇĘýľÝĽÄ´ćĆ÷Ł¬»ńČˇ˝ÓĘŐ»şłĺÇřĘýľÝ */
 449:Core/Src/bsp_spi_flash.c ****   return READ_REG(SpiHandle.Instance->DR);
 450:Core/Src/bsp_spi_flash.c **** }
 451:Core/Src/bsp_spi_flash.c **** 
 452:Core/Src/bsp_spi_flash.c **** /*******************************************************************************
 453:Core/Src/bsp_spi_flash.c **** * Function Name  : SPI_FLASH_SendHalfWord
 454:Core/Src/bsp_spi_flash.c **** * Description    : Sends a Half Word through the SPI interface and return the
 455:Core/Src/bsp_spi_flash.c **** *                  Half Word received from the SPI bus.
 456:Core/Src/bsp_spi_flash.c **** * Input          : Half Word : Half Word to send.
 457:Core/Src/bsp_spi_flash.c **** * Output         : None
 458:Core/Src/bsp_spi_flash.c **** * Return         : The value of the received Half Word.
 459:Core/Src/bsp_spi_flash.c **** *******************************************************************************/
 460:Core/Src/bsp_spi_flash.c **** uint16_t SPI_FLASH_SendHalfWord(uint16_t HalfWord)
 461:Core/Src/bsp_spi_flash.c **** {
 462:Core/Src/bsp_spi_flash.c ****   
 463:Core/Src/bsp_spi_flash.c ****   SPITimeout = SPIT_FLAG_TIMEOUT;
 464:Core/Src/bsp_spi_flash.c **** 
 465:Core/Src/bsp_spi_flash.c ****   /* Loop while DR register in not emplty */
 466:Core/Src/bsp_spi_flash.c ****   while (__HAL_SPI_GET_FLAG( &SpiHandle,  SPI_FLAG_TXE ) == RESET)
 467:Core/Src/bsp_spi_flash.c ****   {
 468:Core/Src/bsp_spi_flash.c ****     if((SPITimeout--) == 0) return SPI_TIMEOUT_UserCallback(2);
 469:Core/Src/bsp_spi_flash.c ****    }
 470:Core/Src/bsp_spi_flash.c **** 
 471:Core/Src/bsp_spi_flash.c ****   /* Send Half Word through the SPIx peripheral */
 472:Core/Src/bsp_spi_flash.c ****   WRITE_REG(SpiHandle.Instance->DR, HalfWord);
 473:Core/Src/bsp_spi_flash.c **** 
 474:Core/Src/bsp_spi_flash.c ****   SPITimeout = SPIT_FLAG_TIMEOUT;
 475:Core/Src/bsp_spi_flash.c **** 
ARM GAS  C:\Users\84759\AppData\Local\Temp\cc86vTnS.s 			page 10


 476:Core/Src/bsp_spi_flash.c ****   /* Wait to receive a Half Word */
 477:Core/Src/bsp_spi_flash.c ****   while (__HAL_SPI_GET_FLAG( &SpiHandle, SPI_FLAG_RXNE ) == RESET)
 478:Core/Src/bsp_spi_flash.c ****    {
 479:Core/Src/bsp_spi_flash.c ****     if((SPITimeout--) == 0) return SPI_TIMEOUT_UserCallback(3);
 480:Core/Src/bsp_spi_flash.c ****    }
 481:Core/Src/bsp_spi_flash.c ****   /* Return the Half Word read from the SPI bus */
 482:Core/Src/bsp_spi_flash.c ****   return READ_REG(SpiHandle.Instance->DR);
 483:Core/Src/bsp_spi_flash.c **** }
 484:Core/Src/bsp_spi_flash.c **** 
