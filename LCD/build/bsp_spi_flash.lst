 381:Core/Src/bsp_spi_flash.c **** /*******************************************************************************
 382:Core/Src/bsp_spi_flash.c **** * Function Name  : SPI_FLASH_StartReadSequence
 383:Core/Src/bsp_spi_flash.c **** * Description    : Initiates a read data byte (READ) sequence from the Flash.
 384:Core/Src/bsp_spi_flash.c **** *                  This is done by driving the /CS line low to select the device,
 385:Core/Src/bsp_spi_flash.c **** *                  then the READ instruction is transmitted followed by 3 bytes
 386:Core/Src/bsp_spi_flash.c **** *                  address. This function exit and keep the /CS line low, so the
 387:Core/Src/bsp_spi_flash.c **** *                  Flash still being selected. With this technique the whole
 388:Core/Src/bsp_spi_flash.c **** *                  content of the Flash is read with a single READ instruction.
 389:Core/Src/bsp_spi_flash.c **** * Input          : - ReadAddr : FLASH's internal address to read from.
 390:Core/Src/bsp_spi_flash.c **** * Output         : None
 391:Core/Src/bsp_spi_flash.c **** * Return         : None
 392:Core/Src/bsp_spi_flash.c **** *******************************************************************************/
 393:Core/Src/bsp_spi_flash.c **** void SPI_FLASH_StartReadSequence(uint32_t ReadAddr)
 394:Core/Src/bsp_spi_flash.c **** {
 395:Core/Src/bsp_spi_flash.c ****   /* Select the FLASH: Chip Select low */
 396:Core/Src/bsp_spi_flash.c ****   SPI_FLASH_CS_LOW();
 397:Core/Src/bsp_spi_flash.c **** 
 398:Core/Src/bsp_spi_flash.c ****   /* Send "Read from Memory " instruction */
 399:Core/Src/bsp_spi_flash.c ****   SPI_FLASH_SendByte(W25X_ReadData);
 400:Core/Src/bsp_spi_flash.c **** 
 401:Core/Src/bsp_spi_flash.c ****   /* Send the 24-bit address of the address to read from -----------------------*/
 402:Core/Src/bsp_spi_flash.c ****   /* Send ReadAddr high nibble address byte */
 403:Core/Src/bsp_spi_flash.c ****   SPI_FLASH_SendByte((ReadAddr & 0xFF0000) >> 16);
 404:Core/Src/bsp_spi_flash.c ****   /* Send ReadAddr medium nibble address byte */
 405:Core/Src/bsp_spi_flash.c ****   SPI_FLASH_SendByte((ReadAddr& 0xFF00) >> 8);
 406:Core/Src/bsp_spi_flash.c ****   /* Send ReadAddr low nibble address byte */
 407:Core/Src/bsp_spi_flash.c ****   SPI_FLASH_SendByte(ReadAddr & 0xFF);
 408:Core/Src/bsp_spi_flash.c **** }
 409:Core/Src/bsp_spi_flash.c **** 
