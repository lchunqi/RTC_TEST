 199:Core/Src/bsp_spi_flash.c **** void SPI_FLASH_BufferWrite(uint8_t* pBuffer, uint32_t WriteAddr, uint16_t NumByteToWrite)
 200:Core/Src/bsp_spi_flash.c **** {
 201:Core/Src/bsp_spi_flash.c ****   uint8_t NumOfPage = 0, NumOfSingle = 0, Addr = 0, count = 0, temp = 0;
 202:Core/Src/bsp_spi_flash.c **** 	
 203:Core/Src/bsp_spi_flash.c **** 	/*modÔËËăÇóÓŕŁ¬ČôwriteAddrĘÇSPI_FLASH_PageSizeŐűĘý±¶Ł¬ÔËËă˝áąűAddrÖµÎŞ0*/
 204:Core/Src/bsp_spi_flash.c ****   Addr = WriteAddr % SPI_FLASH_PageSize;
 205:Core/Src/bsp_spi_flash.c **** 	
 206:Core/Src/bsp_spi_flash.c **** 	/*˛îcount¸öĘýľÝÖµŁ¬¸ŐşĂżÉŇÔ¶ÔĆëµ˝ŇłµŘÖ·*/
 207:Core/Src/bsp_spi_flash.c ****   count = SPI_FLASH_PageSize - Addr;	
 208:Core/Src/bsp_spi_flash.c **** 	/*ĽĆËăłöŇŞĐ´¶ŕÉŮŐűĘýŇł*/
 209:Core/Src/bsp_spi_flash.c ****   NumOfPage =  NumByteToWrite / SPI_FLASH_PageSize;
 210:Core/Src/bsp_spi_flash.c **** 	/*modÔËËăÇóÓŕŁ¬ĽĆËăłöĘŁÓŕ˛»ÂúŇ»ŇłµÄ×Ö˝ÚĘý*/
 211:Core/Src/bsp_spi_flash.c ****   NumOfSingle = NumByteToWrite % SPI_FLASH_PageSize;
 212:Core/Src/bsp_spi_flash.c **** 
 213:Core/Src/bsp_spi_flash.c **** 	 /* Addr=0,ÔňWriteAddr ¸ŐşĂ°´Ňł¶ÔĆë aligned  */
 214:Core/Src/bsp_spi_flash.c ****   if (Addr == 0) 
 215:Core/Src/bsp_spi_flash.c ****   {
 216:Core/Src/bsp_spi_flash.c **** 		/* NumByteToWrite < SPI_FLASH_PageSize */
 217:Core/Src/bsp_spi_flash.c ****     if (NumOfPage == 0) 
 218:Core/Src/bsp_spi_flash.c ****     {
 219:Core/Src/bsp_spi_flash.c ****       SPI_FLASH_PageWrite(pBuffer, WriteAddr, NumByteToWrite);
 220:Core/Src/bsp_spi_flash.c ****     }
 221:Core/Src/bsp_spi_flash.c ****     else /* NumByteToWrite > SPI_FLASH_PageSize */
 222:Core/Src/bsp_spi_flash.c ****     {
 223:Core/Src/bsp_spi_flash.c **** 			/*ĎČ°ŃŐűĘýŇł¶ĽĐ´ÁË*/
 224:Core/Src/bsp_spi_flash.c ****       while (NumOfPage--)
 225:Core/Src/bsp_spi_flash.c ****       {
