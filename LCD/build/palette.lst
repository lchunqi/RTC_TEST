 234:Core/Src/palette.c **** /**
 235:Core/Src/palette.c **** * @brief  Touch_Button_Down 按键被按下时调用的函数，由触摸屏调用
 236:Core/Src/palette.c **** * @param  x 触摸位置的x坐标
 237:Core/Src/palette.c **** * @param  y 触摸位置的y坐标
 238:Core/Src/palette.c **** * @retval 无
 239:Core/Src/palette.c **** */
 240:Core/Src/palette.c **** void Touch_Button_Down(uint16_t x,uint16_t y)
 241:Core/Src/palette.c **** {
 242:Core/Src/palette.c ****   uint8_t i;
 243:Core/Src/palette.c ****   for(i=0;i<BUTTON_NUM;i++)
 244:Core/Src/palette.c ****   {
 245:Core/Src/palette.c ****     /* 触摸到了按钮 */
 246:Core/Src/palette.c ****     if(x<=button[i].end_x && y<=button[i].end_y && y>=button[i].start_y && x>=button[i].start_x )
 247:Core/Src/palette.c ****     {
 248:Core/Src/palette.c ****       if(button[i].touch_flag == 0)     /*原本的状态为没有按下，则更新状态*/
 249:Core/Src/palette.c ****       {
 250:Core/Src/palette.c ****       button[i].touch_flag = 1;         /* 记录按下标志 */
 251:Core/Src/palette.c ****       
 252:Core/Src/palette.c ****       button[i].draw_btn(&button[i]);  /*重绘按钮*/
 253:Core/Src/palette.c ****       }        
 254:Core/Src/palette.c ****       
 255:Core/Src/palette.c ****     }
 256:Core/Src/palette.c ****     else if(button[i].touch_flag == 1) /* 触摸移出了按键的范围且之前有按下按钮 */
 257:Core/Src/palette.c ****     {
 258:Core/Src/palette.c ****       button[i].touch_flag = 0;         /* 清除按下标志，判断为误操作*/
 259:Core/Src/palette.c ****       
 260:Core/Src/palette.c ****       button[i].draw_btn(&button[i]);   /*重绘按钮*/
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccPncmRd.s 			page 6


 261:Core/Src/palette.c ****     }
 262:Core/Src/palette.c **** 
 263:Core/Src/palette.c ****   }
 264:Core/Src/palette.c **** 
 265:Core/Src/palette.c **** }
 266:Core/Src/palette.c **** 
 267:Core/Src/palette.c **** /**
 268:Core/Src/palette.c **** * @brief  Touch_Button_Up 按键被释放时调用的函数，由触摸屏调用
 269:Core/Src/palette.c **** * @param  x 触摸最后释放时的x坐标
 270:Core/Src/palette.c **** * @param  y 触摸最后释放时的y坐标
 271:Core/Src/palette.c **** * @retval 无
 272:Core/Src/palette.c **** */
 273:Core/Src/palette.c **** void Touch_Button_Up(uint16_t x,uint16_t y)
 274:Core/Src/palette.c **** {
 275:Core/Src/palette.c ****    uint8_t i; 
 276:Core/Src/palette.c ****    for(i=0;i<BUTTON_NUM;i++)
 277:Core/Src/palette.c ****    {
 278:Core/Src/palette.c ****      /* 触笔在按钮区域释放 */
 279:Core/Src/palette.c ****       if((x<button[i].end_x && x>button[i].start_x && y<button[i].end_y && y>button[i].start_y))
 280:Core/Src/palette.c ****       {        
 281:Core/Src/palette.c ****         button[i].touch_flag = 0;       /*释放触摸标志*/
 282:Core/Src/palette.c ****         
 283:Core/Src/palette.c ****         button[i].draw_btn(&button[i]); /*重绘按钮*/        
 284:Core/Src/palette.c ****       
 285:Core/Src/palette.c ****         button[i].btn_command(&button[i]);  /*执行按键的功能命令*/
 286:Core/Src/palette.c ****         
 287:Core/Src/palette.c ****         break;
 288:Core/Src/palette.c ****       }
 289:Core/Src/palette.c ****     }  
 290:Core/Src/palette.c **** 
 291:Core/Src/palette.c **** }
 292:Core/Src/palette.c **** 
 293:Core/Src/palette.c **** /**
 294:Core/Src/palette.c **** * @brief  Draw_Trail 在画板区域描绘触摸轨迹
 295:Core/Src/palette.c **** * @param  pre_x 上一点的x坐标
 296:Core/Src/palette.c **** * @param  pre_y 上一点的y坐标
 297:Core/Src/palette.c **** * @param  x     最新一点的x坐标
 298:Core/Src/palette.c **** * @param  y     最新一点的y坐标
 299:Core/Src/palette.c **** * @param  brush 画刷参数
 300:Core/Src/palette.c **** * @retval 无
 301:Core/Src/palette.c **** */
