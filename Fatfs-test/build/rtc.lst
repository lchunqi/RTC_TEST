 162:Core/Src/rtc.c **** 
 163:Core/Src/rtc.c **** uint32_t RTC_DateTimeToSec(uint16_t year, uint8_t month, uint8_t day, uint8_t hour, uint8_t min, ui
 164:Core/Src/rtc.c **** {
 165:Core/Src/rtc.c ****     // 简化版：只计算到 2036 年，足够你用
 166:Core/Src/rtc.c ****     uint16_t mon_day[] = {31,28,31,30,31,30,31,31,30,31,30,31};
 167:Core/Src/rtc.c ****     uint32_t cnt = 0;
 168:Core/Src/rtc.c ****     uint16_t y;
 169:Core/Src/rtc.c ****     uint8_t m;
 170:Core/Src/rtc.c **** 
 171:Core/Src/rtc.c ****     // 年
 172:Core/Src/rtc.c ****     for(y=2000; y<year; y++)
 173:Core/Src/rtc.c ****     {
 174:Core/Src/rtc.c ****         cnt += 365*86400;
 175:Core/Src/rtc.c ****         if((y%4==0 && y%100!=0) || (y%400==0)) cnt += 86400;
 176:Core/Src/rtc.c ****     }
 177:Core/Src/rtc.c ****     // 月
 178:Core/Src/rtc.c ****     for(m=0; m<month-1; m++)
 179:Core/Src/rtc.c ****     {
 180:Core/Src/rtc.c ****         cnt += mon_day[m]*86400;
 181:Core/Src/rtc.c ****         if(m==1 && ((year%4==0&&year%100!=0)||(year%400==0))) cnt +=86400;
 182:Core/Src/rtc.c ****     }
 183:Core/Src/rtc.c ****     // 日时分秒
 184:Core/Src/rtc.c ****     cnt += (day-1)*86400;
 185:Core/Src/rtc.c ****     cnt += hour*3600;
 186:Core/Src/rtc.c ****     cnt += min*60;
 187:Core/Src/rtc.c ****     cnt += sec;
 188:Core/Src/rtc.c **** 
 189:Core/Src/rtc.c ****     return cnt;
 190:Core/Src/rtc.c **** }
