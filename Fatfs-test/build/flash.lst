 117:User/Src/flash.c **** /**
 118:User/Src/flash.c ****  * @brief  扇区擦除 4KB
 119:User/Src/flash.c ****  * @param  addr 24位地址
 120:User/Src/flash.c ****  * @retval 0=成功 1=失败
 121:User/Src/flash.c ****  */
 122:User/Src/flash.c **** uint8_t W25Q64_EraseSector(uint32_t addr)
 123:User/Src/flash.c **** {
 124:User/Src/flash.c ****     uint8_t cmd[4] = {0x20, (addr >> 16) & 0xFF, (addr >> 8) & 0xFF, addr & 0xFF};
 125:User/Src/flash.c ****     uint8_t check_data;
 126:User/Src/flash.c **** 
 127:User/Src/flash.c ****     // 地址越界保护
 128:User/Src/flash.c ****     if (addr > W25Q64_MAX_ADDR)
 129:User/Src/flash.c ****     {
 130:User/Src/flash.c ****         FLASH_LOG("[flash] 地址越界\r\n");
 131:User/Src/flash.c ****         return 1;
 132:User/Src/flash.c ****     }
 133:User/Src/flash.c **** 
 134:User/Src/flash.c ****     if (W25Q64_WriteEnable() != 0) return 1;
 135:User/Src/flash.c **** 
 136:User/Src/flash.c ****     CS_LOW();
 137:User/Src/flash.c ****     if (HAL_SPI_Transmit(&hspi1, cmd, 4, SPI_TIMEOUT_MS) != HAL_OK)
 138:User/Src/flash.c ****     {
 139:User/Src/flash.c ****         CS_HIGH();
 140:User/Src/flash.c ****         W25Q64_WriteDisable();
 141:User/Src/flash.c ****         return 1;
 142:User/Src/flash.c ****     }
 143:User/Src/flash.c ****     CS_HIGH();
 144:User/Src/flash.c **** 
 145:User/Src/flash.c ****     // 等待完成
 146:User/Src/flash.c ****     if (W25Q64_WaitBusy() != 0)
 147:User/Src/flash.c ****     {
 148:User/Src/flash.c ****         FLASH_LOG("[flash] 擦除超时\r\n");
 149:User/Src/flash.c ****         W25Q64_WriteDisable();
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccXx1pSI.s 			page 12


 150:User/Src/flash.c ****         return 1;
 151:User/Src/flash.c ****     }
 152:User/Src/flash.c **** 
 153:User/Src/flash.c ****     // 擦除校验
 154:User/Src/flash.c ****     W25Q64_ReadData(addr, &check_data, 1);
 155:User/Src/flash.c ****     if (check_data != 0xFF)
 156:User/Src/flash.c ****     {
 157:User/Src/flash.c ****         FLASH_LOG("[flash] 擦除校验失败\r\n");
 158:User/Src/flash.c ****         W25Q64_WriteDisable();
 159:User/Src/flash.c ****         return 1;
 160:User/Src/flash.c ****     }
 161:User/Src/flash.c **** 
 162:User/Src/flash.c ****     W25Q64_WriteDisable();
 163:User/Src/flash.c ****     FLASH_LOG("[flash] 扇区擦除成功\r\n");
 164:User/Src/flash.c ****     return 0;
 165:User/Src/flash.c **** }
