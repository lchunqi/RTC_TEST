  88:User/Src/command.c **** uint8_t CharToInt(char* source, uint8_t start, int* number)
  89:User/Src/command.c **** {
  90:User/Src/command.c **** 	uint8_t length;
  91:User/Src/command.c **** 	uint8_t i;
  92:User/Src/command.c **** 	int sum = 0;
  93:User/Src/command.c **** 	int state = 0;
  94:User/Src/command.c **** 	uint8_t hex = 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\cciJwIRS.s 			page 5


  95:User/Src/command.c **** 	length = strlen(source);
  96:User/Src/command.c **** 	if (start >= length) {
  97:User/Src/command.c **** 		*number = 0;
  98:User/Src/command.c **** 		return 0;
  99:User/Src/command.c **** 	}
 100:User/Src/command.c **** 	if (source[start] == '-') {
 101:User/Src/command.c **** 		state = -1;
 102:User/Src/command.c **** 		start++;
 103:User/Src/command.c **** 	} else {
 104:User/Src/command.c **** 		state = 1;
 105:User/Src/command.c **** 		if (start + 1 < length ) {
 106:User/Src/command.c **** 			if (source[start] == '0' && (source[start + 1] == 'x' ||source[start + 1] == 'X')) {
 107:User/Src/command.c **** 				start += 2;
 108:User/Src/command.c **** 				hex = 1;
 109:User/Src/command.c **** 			}
 110:User/Src/command.c **** 		}
 111:User/Src/command.c **** 	}
 112:User/Src/command.c **** 	for (i = start; i < length; i++) {
 113:User/Src/command.c **** 		if (source[i] >= '0' && source[i] <= '9') {
 114:User/Src/command.c **** 			if (hex == 1) {
 115:User/Src/command.c **** 				sum = sum * 16 + source[i] - '0';
 116:User/Src/command.c **** 			} else {
 117:User/Src/command.c **** 				sum = sum * 10 + source[i] - '0';
 118:User/Src/command.c **** 			}
 119:User/Src/command.c **** 		} else if (source[i] >= 'a' && source[i] <= 'f') {
 120:User/Src/command.c **** 			if (hex == 1) {
 121:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'a' + 10;
 122:User/Src/command.c **** 			} else {
 123:User/Src/command.c **** 				*number = 0;
 124:User/Src/command.c **** 				return 0;
 125:User/Src/command.c **** 			}
 126:User/Src/command.c **** 		}else if (source[i] >= 'A' && source[i] <= 'F') {
 127:User/Src/command.c **** 			if (hex == 1) {
 128:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'A' + 10;
 129:User/Src/command.c **** 			} else {
 130:User/Src/command.c **** 				*number = 0;
 131:User/Src/command.c **** 				return 0;
 132:User/Src/command.c **** 			}
 133:User/Src/command.c **** 		} else if (source[i] == ' ' || source[i] == ',') {
 134:User/Src/command.c **** 			break;
 135:User/Src/command.c **** 		}
 136:User/Src/command.c **** 	}
 137:User/Src/command.c **** 	*number = state * sum;
 138:User/Src/command.c **** 	return 1;
 139:User/Src/command.c **** }
