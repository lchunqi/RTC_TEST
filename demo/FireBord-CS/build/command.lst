 141:User/Src/command.c **** uint8_t CharToFloat(char* source, uint8_t start, float* number)
 142:User/Src/command.c **** {
 143:User/Src/command.c **** 		uint8_t length;
 144:User/Src/command.c **** 		uint8_t i;
 145:User/Src/command.c **** 		float sum = 0;
 146:User/Src/command.c **** 		int state = 1;
 147:User/Src/command.c **** 		float smallNumber = 0.1;
 148:User/Src/command.c **** 		length = strlen(source);
 149:User/Src/command.c **** 		if (length <= start) {
 150:User/Src/command.c **** 				*number = 0;
 151:User/Src/command.c **** 				return 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\cciJwIRS.s 			page 6


 152:User/Src/command.c **** 		}
 153:User/Src/command.c **** 		
 154:User/Src/command.c **** 		if (source[start] == '-') {
 155:User/Src/command.c **** 				state = -1;
 156:User/Src/command.c **** 				start++;
 157:User/Src/command.c **** 		}
 158:User/Src/command.c **** 		for (i = start; i < length; i++){
 159:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 160:User/Src/command.c **** 						sum = sum * 10 + source[i] - '0';
 161:User/Src/command.c **** 				} else if (source[i] == '.') {
 162:User/Src/command.c **** 						i++;
 163:User/Src/command.c **** 						break;
 164:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 165:User/Src/command.c **** 						break;
 166:User/Src/command.c **** 				}	else {
 167:User/Src/command.c **** 						*number = 0;
 168:User/Src/command.c **** 						return 0;
 169:User/Src/command.c **** 				}					
 170:User/Src/command.c **** 		}
 171:User/Src/command.c **** 		for (; i < length; i++) {
 172:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 173:User/Src/command.c **** 						sum += smallNumber * (source[i] - '0');
 174:User/Src/command.c **** 						smallNumber = smallNumber * 0.1;
 175:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 176:User/Src/command.c **** 						break;
 177:User/Src/command.c **** 				}	else {
 178:User/Src/command.c **** 						*number = 0;
 179:User/Src/command.c **** 						return 0;
 180:User/Src/command.c **** 				}	
 181:User/Src/command.c **** 		}
 182:User/Src/command.c **** 		*number = state * sum;
 183:User/Src/command.c **** 		return 1;
 184:User/Src/command.c **** }
