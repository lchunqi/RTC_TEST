 245:User/Src/command.c **** 				flag=i2c_read_multi_bytes(0x64, reg, buffer, 8);
 246:User/Src/command.c **** 				UsbPrintf("read error flag=%d !\n",flag);
 247:User/Src/command.c **** 			}
 248:User/Src/command.c **** 			break;
 249:User/Src/command.c **** 		case 0XB2:
 250:User/Src/command.c **** 			if (i2c_read_multi_bytes(0x64, reg, buffer, 8) == I2C_OK) {
 251:User/Src/command.c **** 				UsbPrintf("id:%02X%02X%02X%02X%02X%02X%02X%02X\n", buffer[0], buffer[1], buffer[2], buffer[3], 
 252:User/Src/command.c **** 			}else if(i2c_read_multi_bytes(0xD0, reg, buffer, 8) == I2C_OK){
 253:User/Src/command.c **** 				UsbPrintf("id:%02X%02X%02X%02X%02X%02X%02X%02X\n", buffer[0], buffer[1], buffer[2], buffer[3], 
 254:User/Src/command.c **** 			}
 255:User/Src/command.c **** 			break;
 256:User/Src/command.c **** 
