  71:User/Src/command.c **** int strSearch(char* source, char* target)
  72:User/Src/command.c **** {
  73:User/Src/command.c **** 	int len_source = strlen(source);
  74:User/Src/command.c **** 	int len_target = strlen(target);
  75:User/Src/command.c **** 	int i, j;
  76:User/Src/command.c **** 	if (len_source < len_target) {
  77:User/Src/command.c **** 		return -1;
  78:User/Src/command.c **** 	}		
  79:User/Src/command.c **** 	for (i = 0; i <= len_source - len_target; i++) {
  80:User/Src/command.c **** 		for (j = 0; j < len_target; j++) {
  81:User/Src/command.c **** 			if (source[i + j] != target[j]) { break;}
  82:User/Src/command.c **** 		}
  83:User/Src/command.c **** 		if (j == len_target) { return i;}
  84:User/Src/command.c **** 	}
  85:User/Src/command.c **** 	return -1;	
  86:User/Src/command.c **** }
