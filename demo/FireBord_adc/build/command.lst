 141:User/Src/command.c **** uint8_t CharToFloat(char* source, uint8_t start, float* number)
 142:User/Src/command.c **** {
 143:User/Src/command.c **** 		uint8_t length;
 144:User/Src/command.c **** 		uint8_t i;
 145:User/Src/command.c **** 		float sum = 0;
 146:User/Src/command.c **** 		int state = 1;
 147:User/Src/command.c **** 		float smallNumber = 0.1;
 148:User/Src/command.c **** 		length = strlen(source);
 149:User/Src/command.c **** 		if (length <= start) {
 150:User/Src/command.c **** 				*number = 0;
 151:User/Src/command.c **** 				return 0;
