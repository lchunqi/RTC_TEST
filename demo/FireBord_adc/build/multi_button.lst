  45:User/Src/multi_button.c **** {
  46:User/Src/multi_button.c **** 	handle->cb[event] = cb;
  47:User/Src/multi_button.c **** }
  48:User/Src/multi_button.c **** 
  49:User/Src/multi_button.c **** /**
