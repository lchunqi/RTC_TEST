 173:Core/Src/main.c ****       BYTE work[4096];    // 强制4096字节缓冲区，避免宏定义问题
 174:Core/Src/main.c ****       
 175:Core/Src/main.c ****       // 初始化MKFS_PARM结构体（严格适配W25Q16 2MB）
 176:Core/Src/main.c ****       MKFS_PARM mkfs_param = {0};
 177:Core/Src/main.c ****       mkfs_param.fmt      = FM_FAT | FM_SFD ; // FAT16 + 单分区（2MB仅支持FAT16）
