 593:Core/Src/flash.c **** // 读取W25Q64设备ID（返回0xEF17为正常，对接diskio.c校验）
 594:Core/Src/flash.c **** uint16_t flash_device_id(void)
 595:Core/Src/flash.c **** {
 596:Core/Src/flash.c ****     uint16_t id = 0;
 597:Core/Src/flash.c ****     CS_LOW;
 598:Core/Src/flash.c ****     SPI1_ReadWriteByte(W25Q_ReadID);    // 读ID指令
 599:Core/Src/flash.c ****     SPI1_ReadWriteByte(0x00);           // 地址位A23-A16
 600:Core/Src/flash.c ****     SPI1_ReadWriteByte(0x00);           // 地址位A15-A8
 601:Core/Src/flash.c ****     SPI1_ReadWriteByte(0x00);           // 地址位A7-A0
 602:Core/Src/flash.c ****     id |= (uint16_t)SPI1_ReadWriteByte(0xFF) << 8; // 厂家ID 0xEF
 603:Core/Src/flash.c ****     id |= SPI1_ReadWriteByte(0xFF);                // 设备ID 0x17
 604:Core/Src/flash.c ****     CS_HIGH;
 605:Core/Src/flash.c ****     return id;
 606:Core/Src/flash.c **** }
 607:Core/Src/flash.c **** 
 608:Core/Src/flash.c **** // 4KB扇区擦除（diskio.c专用，返回1=成功，0=失败）
 609:Core/Src/flash.c **** int flash_erase_sector(uint32_t address)
 610:Core/Src/flash.c **** {
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDemNcb.s 			page 15


 611:Core/Src/flash.c ****     // 地址必须4KB扇区对齐（W25Q64硬件要求）
 612:Core/Src/flash.c ****     if((address & (SECTOR_SIZE - 1)) != 0) return 0;
 613:Core/Src/flash.c ****     
 614:Core/Src/flash.c ****     W25Qxx_WriteEnable();  // 写使能
 615:Core/Src/flash.c ****     CheckBusy();         // 等待前序操作完成
 616:Core/Src/flash.c ****     CS_LOW;
 617:Core/Src/flash.c ****     SPI1_ReadWriteByte(W25Q_EraseSector); // 4KB扇区擦除指令
 618:Core/Src/flash.c ****     // 发送24位擦除地址
 619:Core/Src/flash.c ****     SPI1_ReadWriteByte((address >> 16) & 0xFF);
 620:Core/Src/flash.c ****     SPI1_ReadWriteByte((address >> 8) & 0xFF);
 621:Core/Src/flash.c ****     SPI1_ReadWriteByte(address & 0xFF);
 622:Core/Src/flash.c ****     CS_HIGH;
 623:Core/Src/flash.c ****     CheckBusy();         // 等待擦除完成（擦除耗时约100ms）
 624:Core/Src/flash.c ****     return 1;            // 1=成功，对接diskio.c返回值逻辑
 625:Core/Src/flash.c **** }
