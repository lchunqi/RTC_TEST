 496:Core/Src/flash.c **** void SaveStringToFlash(char* s, uint32_t addr)
 497:Core/Src/flash.c **** {
 498:Core/Src/flash.c **** 	int length = strlen(s);
 499:Core/Src/flash.c **** 	uint16_t j;
 500:Core/Src/flash.c **** 	uint32_t data = 0;
 501:Core/Src/flash.c **** 	uint32_t address = addr;
 502:Core/Src/flash.c **** 	if (length <= 0) {return;}
 503:Core/Src/flash.c **** 
 504:Core/Src/flash.c **** 	HAL_FLASH_Unlock();
 505:Core/Src/flash.c **** 	for (j = 0; j < length; j += 4) {
 506:Core/Src/flash.c **** 		if (j + 4 <= length) {
 507:Core/Src/flash.c **** 			data = s[j] + ((uint32_t)s[j + 1] << 8) + ((uint32_t)s[j + 2] << 16)+ ((uint32_t)s[j + 3] << 24)
 508:Core/Src/flash.c **** 		} else {
 509:Core/Src/flash.c **** 			if (length == j + 1) { 
 510:Core/Src/flash.c **** 				data = s[j];
 511:Core/Src/flash.c **** 			} else if (length == j + 2) { 
 512:Core/Src/flash.c **** 				data =  s[j] + ((uint32_t)s[j + 1] << 8);
 513:Core/Src/flash.c **** 			} else if (length == j + 3) { 
 514:Core/Src/flash.c **** 				data =  s[j] + ((uint32_t)s[j + 1] << 8) + ((uint32_t)s[j + 2] << 16);
 515:Core/Src/flash.c **** 			} 
 516:Core/Src/flash.c **** 		}
 517:Core/Src/flash.c **** 		HAL_FLASH_Program(FLASH_TYPEPROGRAM_WORD, address, data);
 518:Core/Src/flash.c **** 		address += 4;
 519:Core/Src/flash.c **** 	}
 520:Core/Src/flash.c **** 	HAL_FLASH_Lock();
 521:Core/Src/flash.c **** }
 522:Core/Src/flash.c **** void GetStringFromFlash(char* target, uint16_t length, uint32_t addr)
 523:Core/Src/flash.c **** {
 524:Core/Src/flash.c **** 	uint16_t i;
 525:Core/Src/flash.c **** 	uint32_t value;
 526:Core/Src/flash.c **** 
 527:Core/Src/flash.c **** 	for (i = 0; i < length; i++) {
 528:Core/Src/flash.c **** 		value = *(uint8_t*)(addr + i);
 529:Core/Src/flash.c **** 		if (value == 0xff || value == 0) {
 530:Core/Src/flash.c **** 			target[i] = 0;
 531:Core/Src/flash.c **** 			break;
 532:Core/Src/flash.c **** 		}
 533:Core/Src/flash.c **** 		target[i] = value;
 534:Core/Src/flash.c **** 	}
 535:Core/Src/flash.c **** }
