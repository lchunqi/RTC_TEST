   9:Core/Src/flash.c **** //--------------------------------
  10:Core/Src/flash.c **** // flash_read_data函数和flash_write_data函数是最底层的函数
  11:Core/Src/flash.c **** // 可以对25Q64系列的flash进行读写操作
  12:Core/Src/flash.c **** // 但是要注意的是，读和写的长度不能超过页，否则会数据出错
  13:Core/Src/flash.c **** // 另外的封装函数固定读取某些部分的数据，在设计的时候就避免了数据越界
  14:Core/Src/flash.c **** //------------------------------
  15:Core/Src/flash.c **** #define ERASE_SECTOR_ADDR   0x20                   // 
  16:Core/Src/flash.c **** #define ERASE_BLOCK_ADDR    0xd8                    //
  17:Core/Src/flash.c **** #define ERASE_CHIP_ADDR     0xC7                    // 
  18:Core/Src/flash.c **** 
  19:Core/Src/flash.c **** extern SPI_HandleTypeDef hspi1;
  20:Core/Src/flash.c **** #define W25Q64SPI hspi1
  21:Core/Src/flash.c **** uint8_t w25x_read_id = 0x90;                    // 
  22:Core/Src/flash.c **** uint8_t check_addr   = 0x05;                    // 
  23:Core/Src/flash.c **** uint8_t enable_write = 0x06;                    // 
  24:Core/Src/flash.c **** uint8_t write_addr   = 0x02;                    // 
  25:Core/Src/flash.c **** uint8_t read_addr    = 0x03;                    //
  26:Core/Src/flash.c **** uint8_t g_bufferSector[SECTOR_SIZE];
  27:Core/Src/flash.c **** 
  28:Core/Src/flash.c **** 
  29:Core/Src/flash.c **** int CheckBusy(void)
  30:Core/Src/flash.c **** {
  31:Core/Src/flash.c ****     uint8_t status = 1;
  32:Core/Src/flash.c ****     int timeCount = 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDemNcb.s 			page 2


  33:Core/Src/flash.c **** 
  34:Core/Src/flash.c ****     for (timeCount = 0; timeCount < 20; timeCount++) {
  35:Core/Src/flash.c ****         CS_LOW;
  36:Core/Src/flash.c ****         HAL_SPI_Transmit(&W25Q64SPI, &check_addr, 1, 10);
  37:Core/Src/flash.c ****         HAL_SPI_Receive(&W25Q64SPI, &status, 1, 10);
  38:Core/Src/flash.c ****         CS_HIGH;
  39:Core/Src/flash.c ****         if ((status & 0x01) == 0) { return 1; }
  40:Core/Src/flash.c ****         HAL_Delay(1);
  41:Core/Src/flash.c ****     }
  42:Core/Src/flash.c ****     return 0;
  43:Core/Src/flash.c **** }
  44:Core/Src/flash.c **** 
  45:Core/Src/flash.c **** uint16_t flash1_device_id(void)
  46:Core/Src/flash.c **** {
  47:Core/Src/flash.c ****     uint8_t buff[5] = {0,0,0,0,0};
  48:Core/Src/flash.c ****     uint16_t deviceId = 0;
  49:Core/Src/flash.c ****     CS_LOW;
  50:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &w25x_read_id, 1, 10);
  51:Core/Src/flash.c ****     HAL_SPI_Receive(&W25Q64SPI, buff, 5, 10);
  52:Core/Src/flash.c ****     CS_HIGH;
  53:Core/Src/flash.c ****     UsbPrintf("flash ID is 0x%x%x\n", buff[3], buff[4]);
  54:Core/Src/flash.c ****     deviceId = buff[3];
  55:Core/Src/flash.c ****     deviceId = deviceId * 256 + buff[4];
  56:Core/Src/flash.c ****     return deviceId; 
  57:Core/Src/flash.c **** }
  58:Core/Src/flash.c **** 
  59:Core/Src/flash.c **** void address_32_to_8(uint32_t address, uint8_t* addr8)
  60:Core/Src/flash.c **** {
  61:Core/Src/flash.c ****     int i;
  62:Core/Src/flash.c ****     for (i = 2; i >= 0; i--) {
  63:Core/Src/flash.c ****         addr8[i] = address % 256;
  64:Core/Src/flash.c ****         address = address / 256;
  65:Core/Src/flash.c ****     }
  66:Core/Src/flash.c **** }
  67:Core/Src/flash.c **** 
  68:Core/Src/flash.c **** int flash_erase(uint32_t address, uint8_t mode)
  69:Core/Src/flash.c **** {
  70:Core/Src/flash.c ****     uint8_t erase_address;
  71:Core/Src/flash.c ****     uint8_t addr[3] = {0};
  72:Core/Src/flash.c **** 
  73:Core/Src/flash.c ****     address_32_to_8(address, addr);
  74:Core/Src/flash.c ****     if (CheckBusy() <= 0) {
  75:Core/Src/flash.c ****         return -1;
  76:Core/Src/flash.c ****     }
  77:Core/Src/flash.c ****     CS_LOW;
  78:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &enable_write, 1, 10);
  79:Core/Src/flash.c ****     CS_HIGH;
  80:Core/Src/flash.c ****     switch (mode) {
  81:Core/Src/flash.c ****         case 0:
  82:Core/Src/flash.c ****             erase_address = ERASE_CHIP_ADDR;
  83:Core/Src/flash.c ****             break;
  84:Core/Src/flash.c ****         case 1:
  85:Core/Src/flash.c ****             erase_address = ERASE_BLOCK_ADDR;
  86:Core/Src/flash.c ****             break;
  87:Core/Src/flash.c ****         case 2:
  88:Core/Src/flash.c ****             erase_address = ERASE_SECTOR_ADDR;
  89:Core/Src/flash.c ****             break;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDemNcb.s 			page 3


  90:Core/Src/flash.c ****         default:
  91:Core/Src/flash.c ****             return 0;
  92:Core/Src/flash.c ****             break;
  93:Core/Src/flash.c ****     }
  94:Core/Src/flash.c ****     
  95:Core/Src/flash.c ****     CS_LOW;
  96:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &erase_address, 1, 10);//
  97:Core/Src/flash.c ****     if (mode != 0) {                                    // 
  98:Core/Src/flash.c ****         HAL_SPI_Transmit(&W25Q64SPI, addr, 3, 10);      //
  99:Core/Src/flash.c ****     }
 100:Core/Src/flash.c ****     CS_HIGH;
 101:Core/Src/flash.c ****     return 1;
 102:Core/Src/flash.c **** }
 103:Core/Src/flash.c **** 
 104:Core/Src/flash.c **** int flash_write_data(uint32_t address, uint8_t* buffer, uint16_t size)
 105:Core/Src/flash.c **** {
 106:Core/Src/flash.c ****     uint8_t addr[3] = {0};
 107:Core/Src/flash.c **** 
 108:Core/Src/flash.c ****     if (address >= FLASH_END_ADDR || size > PAGE_SIZE) {
 109:Core/Src/flash.c ****         return 0;
 110:Core/Src/flash.c ****     }
 111:Core/Src/flash.c ****     if (CheckBusy() == 0) { return 0;  }
 112:Core/Src/flash.c ****     address_32_to_8(address, addr);
 113:Core/Src/flash.c ****     CS_LOW;
 114:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &enable_write, 1, 10);//
 115:Core/Src/flash.c ****     CS_HIGH;
 116:Core/Src/flash.c ****     if (CheckBusy() <= 0) {
 117:Core/Src/flash.c ****         return -1;
 118:Core/Src/flash.c ****     } 
 119:Core/Src/flash.c **** 
 120:Core/Src/flash.c ****     CS_LOW;
 121:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &write_addr, 1, 10);//
 122:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, addr, 3, 10);//
 123:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, buffer, size, 10);//
 124:Core/Src/flash.c ****     CS_HIGH;
 125:Core/Src/flash.c ****     return 1;
 126:Core/Src/flash.c **** }
 127:Core/Src/flash.c **** 
 128:Core/Src/flash.c **** int flash_read_data(uint32_t address, uint8_t* buffer, uint16_t length)
 129:Core/Src/flash.c **** {
 130:Core/Src/flash.c ****     uint8_t addr[3] = {0};
 131:Core/Src/flash.c ****     if (address >= FLASH_END_ADDR || length > PAGE_SIZE) {
 132:Core/Src/flash.c ****         return 0;
 133:Core/Src/flash.c ****     }
 134:Core/Src/flash.c ****     if (CheckBusy() == 0) { return 0;  }
 135:Core/Src/flash.c ****     address_32_to_8(address, addr);
 136:Core/Src/flash.c ****     CS_LOW;
 137:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI, &read_addr, 1, 10);
 138:Core/Src/flash.c ****     HAL_SPI_Transmit(&W25Q64SPI,addr, 3, 10);
 139:Core/Src/flash.c ****     HAL_SPI_Receive(&W25Q64SPI, buffer, length, 50);
 140:Core/Src/flash.c ****     CS_HIGH;
 141:Core/Src/flash.c ****     return 1;
 142:Core/Src/flash.c **** }
 143:Core/Src/flash.c **** 
 144:Core/Src/flash.c **** void float_to_uint8(uint8_t* target, float* source)
 145:Core/Src/flash.c **** {
 146:Core/Src/flash.c ****     uint32_t sum = 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDemNcb.s 			page 4


 147:Core/Src/flash.c ****     int i;
 148:Core/Src/flash.c ****     sum = *((uint32_t *)source);
 149:Core/Src/flash.c ****     for (i = 3; i >= 0; i--) {
 150:Core/Src/flash.c ****         target[i] = sum % 256;
 151:Core/Src/flash.c ****         sum = sum >> 8;
 152:Core/Src/flash.c ****     }
 153:Core/Src/flash.c **** }
 154:Core/Src/flash.c **** void uint8_to_float(float* target, uint8_t* source)
 155:Core/Src/flash.c **** {
 156:Core/Src/flash.c ****     uint32_t sum = 0;
 157:Core/Src/flash.c ****     int i;
 158:Core/Src/flash.c ****     for (i = 0; i < 4; i++) {
 159:Core/Src/flash.c ****         sum = (sum << 8) + source[i];
 160:Core/Src/flash.c ****     }
 161:Core/Src/flash.c ****     if (sum == 0xffffffff) {
 162:Core/Src/flash.c ****         *target = -16777215;
 163:Core/Src/flash.c ****     } else {
 164:Core/Src/flash.c ****         *target = *((float*)&sum);
 165:Core/Src/flash.c ****     }
 166:Core/Src/flash.c **** }
 167:Core/Src/flash.c **** 
 168:Core/Src/flash.c **** int flash_test_flag_manage(uint8_t* buffer, TestFlagList handle, TestFlagHandle mode)
 169:Core/Src/flash.c **** {
 170:Core/Src/flash.c ****     uint32_t address;
 171:Core/Src/flash.c ****     int i;
 172:Core/Src/flash.c ****     uint8_t writeBuffer[PAGE_SIZE * 6] = {0xff};
 173:Core/Src/flash.c ****     switch (mode) {
 174:Core/Src/flash.c ****         case FLASH_FLAG_READ:
 175:Core/Src/flash.c ****             address = TEST_FALG_START_ADDR + handle * PAGE_SIZE;
 176:Core/Src/flash.c ****             flash_read_data(address, buffer, MAX_CHIP_NUMBER);
 177:Core/Src/flash.c ****         break;
 178:Core/Src/flash.c ****         case FLASH_FLAG_WRITE_ADD:
 179:Core/Src/flash.c ****             address = TEST_FALG_START_ADDR + handle * PAGE_SIZE;
 180:Core/Src/flash.c ****             flash_write_data(address, buffer, MAX_CHIP_NUMBER);
 181:Core/Src/flash.c ****         break;
 182:Core/Src/flash.c ****         case FLASH_FLAG_WRITE_COVER:
 183:Core/Src/flash.c ****             for (i = 0; i < 6; i++) {
 184:Core/Src/flash.c ****                 flash_read_data(TEST_FALG_START_ADDR + i * PAGE_SIZE, writeBuffer + i * PAGE_SIZE, 
 185:Core/Src/flash.c ****             }
 186:Core/Src/flash.c ****             for (i = 0; i < MAX_CHIP_NUMBER; i++) {
 187:Core/Src/flash.c ****                 writeBuffer[PAGE_SIZE * handle + i] = buffer[i];
 188:Core/Src/flash.c ****             }
 189:Core/Src/flash.c ****             HAL_Delay(5);
 190:Core/Src/flash.c **** 
 191:Core/Src/flash.c ****             flash_erase(TEST_FALG_START_ADDR, 2);//erase the sector    
 192:Core/Src/flash.c ****             HAL_Delay(50);
 193:Core/Src/flash.c **** 
 194:Core/Src/flash.c ****             for (i = 0; i < 6; i++) {
 195:Core/Src/flash.c ****                 flash_write_data(TEST_FALG_START_ADDR + i * PAGE_SIZE, writeBuffer+ i * PAGE_SIZE, 
 196:Core/Src/flash.c ****                 HAL_Delay(5);
 197:Core/Src/flash.c ****             }
 198:Core/Src/flash.c ****         break;
 199:Core/Src/flash.c ****         default:
 200:Core/Src/flash.c ****         break;
 201:Core/Src/flash.c ****     }
 202:Core/Src/flash.c **** 
 203:Core/Src/flash.c ****     return 1;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDemNcb.s 			page 5


 204:Core/Src/flash.c **** }
 205:Core/Src/flash.c **** 
 206:Core/Src/flash.c **** void flash_test_data_read(TestResult* result, uint8_t rtcNumber, TestResultList handle)
 207:Core/Src/flash.c **** {
