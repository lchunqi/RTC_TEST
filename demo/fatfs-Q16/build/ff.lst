1414:Core/FatFs/Src/ff.c **** /*---------------------------------------------*/
1415:Core/FatFs/Src/ff.c **** /* Fill the last fragment of the FAT chain     */
1416:Core/FatFs/Src/ff.c **** /*---------------------------------------------*/
1417:Core/FatFs/Src/ff.c **** 
1418:Core/FatFs/Src/ff.c **** static FRESULT fill_last_frag (
1419:Core/FatFs/Src/ff.c **** 	FFOBJID* obj,	/* Pointer to the corresponding object */
1420:Core/FatFs/Src/ff.c **** 	DWORD lcl,		/* Last cluster of the fragment */
1421:Core/FatFs/Src/ff.c **** 	DWORD term		/* Value to set the last FAT entry */
1422:Core/FatFs/Src/ff.c **** )
1423:Core/FatFs/Src/ff.c **** {
