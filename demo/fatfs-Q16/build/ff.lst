7015:Core/FatFs/Src/ff.c **** 					exp = ilog10(val);
7016:Core/FatFs/Src/ff.c **** 					if (exp > 99 || prec + 7 >= SZ_NUM_BUF) {	/* Buffer overflow or E > +99? */
7017:Core/FatFs/Src/ff.c **** 						er = "OV";
7018:Core/FatFs/Src/ff.c **** 					} else {
7019:Core/FatFs/Src/ff.c **** 						if (exp < -99) exp = -99;
7020:Core/FatFs/Src/ff.c **** 						val /= i10x(exp);	/* Normalize */
7021:Core/FatFs/Src/ff.c **** 					}
7022:Core/FatFs/Src/ff.c **** 				}
7023:Core/FatFs/Src/ff.c **** 			}
7024:Core/FatFs/Src/ff.c **** 		}
7025:Core/FatFs/Src/ff.c **** 		if (!er) {	/* Not error condition */
7026:Core/FatFs/Src/ff.c **** 			if (sign == '-') *buf++ = sign;	/* Add a - if negative value */
