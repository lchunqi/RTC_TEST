3875:Core/FatFs/Src/ff.c **** 					st_32(dj.dir + DIR_CrtTime, tm);	/* Set created time */
3876:Core/FatFs/Src/ff.c **** 					st_32(dj.dir + DIR_ModTime, tm);	/* Set modified time (tmp setting) */
3877:Core/FatFs/Src/ff.c **** 					cl = ld_clust(fs, dj.dir);			/* Get current cluster chain */
3878:Core/FatFs/Src/ff.c **** 					dj.dir[DIR_Attr] = AM_ARC;			/* Reset attribute */
3879:Core/FatFs/Src/ff.c **** 					st_clust(fs, dj.dir, 0);			/* Reset file allocation info */
3880:Core/FatFs/Src/ff.c **** 					st_32(dj.dir + DIR_FileSize, 0);
