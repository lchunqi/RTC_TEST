1402:Core/FatFs/Src/ff.c **** 
1403:Core/FatFs/Src/ff.c **** 	if (obj->stat == 3) {	/* Has the object been changed 'fragmented' in this session? */
1404:Core/FatFs/Src/ff.c **** 		for (cl = obj->sclust, n = obj->n_cont; n; cl++, n--) {	/* Create cluster chain on the FAT */
1405:Core/FatFs/Src/ff.c **** 			res = put_fat(obj->fs, cl, cl + 1);
1406:Core/FatFs/Src/ff.c **** 			if (res != FR_OK) return res;
1407:Core/FatFs/Src/ff.c **** 		}
