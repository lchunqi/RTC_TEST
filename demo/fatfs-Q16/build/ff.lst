3850:Core/FatFs/Src/ff.c **** 				}
3851:Core/FatFs/Src/ff.c **** 			}
3852:Core/FatFs/Src/ff.c **** 			if (res == FR_OK && (mode & FA_CREATE_ALWAYS)) {	/* Truncate the file if overwrite mode */
3853:Core/FatFs/Src/ff.c **** 				DWORD tm = GET_FATTIME();
3854:Core/FatFs/Src/ff.c **** #if FF_FS_EXFAT
3855:Core/FatFs/Src/ff.c **** 				if (fs->fs_type == FS_EXFAT) {
3856:Core/FatFs/Src/ff.c **** 					/* Get current allocation info */
3857:Core/FatFs/Src/ff.c **** 					init_alloc_info(&fp->obj, 0);
3858:Core/FatFs/Src/ff.c **** 					/* Set exFAT directory entry block initial state */
3859:Core/FatFs/Src/ff.c **** 					memset(fs->dirbuf + 2, 0, 30);	/* Clear 85 entry except for NumSec */
3860:Core/FatFs/Src/ff.c **** 					memset(fs->dirbuf + 38, 0, 26);	/* Clear C0 entry except for NumName and NameHash */
3861:Core/FatFs/Src/ff.c **** 					fs->dirbuf[XDIR_Attr] = AM_ARC;
3862:Core/FatFs/Src/ff.c **** 					st_32(fs->dirbuf + XDIR_CrtTime, tm);	/* Set created time */
3863:Core/FatFs/Src/ff.c **** 					st_32(fs->dirbuf + XDIR_ModTime, tm);	/* Set modified time (tmp setting) */
3864:Core/FatFs/Src/ff.c **** 					fs->dirbuf[XDIR_GenFlags] = 1;
3865:Core/FatFs/Src/ff.c **** 					res = store_xdir(&dj);
3866:Core/FatFs/Src/ff.c **** 					if (res == FR_OK && fp->obj.sclust != 0) {	/* Remove the cluster chain if exist */
3867:Core/FatFs/Src/ff.c **** 						res = remove_chain(&fp->obj, fp->obj.sclust, 0);
3868:Core/FatFs/Src/ff.c **** 						fs->last_clst = fp->obj.sclust - 1;		/* Reuse the cluster hole */
3869:Core/FatFs/Src/ff.c **** 					}
3870:Core/FatFs/Src/ff.c **** 				} else
3871:Core/FatFs/Src/ff.c **** #endif
3872:Core/FatFs/Src/ff.c **** 				{
3873:Core/FatFs/Src/ff.c **** 					DWORD cl;
