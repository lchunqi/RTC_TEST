1393:Core/FatFs/Src/ff.c **** /*---------------------------------------------*/
1394:Core/FatFs/Src/ff.c **** 
1395:Core/FatFs/Src/ff.c **** static FRESULT fill_first_frag (
1396:Core/FatFs/Src/ff.c **** 	FFOBJID* obj	/* Pointer to the corresponding object */
1397:Core/FatFs/Src/ff.c **** )
1398:Core/FatFs/Src/ff.c **** {
