  37:Core/FatFs/Src/ff.c **** /* Limits and boundaries */
  38:Core/FatFs/Src/ff.c **** #define MAX_DIR		0x200000		/* Max size of FAT directory (byte) */
  39:Core/FatFs/Src/ff.c **** #define MAX_DIR_EX	0x10000000		/* Max size of exFAT directory (byte) */
  40:Core/FatFs/Src/ff.c **** #define MAX_FAT12	0xFF5			/* Max FAT12 clusters (differs from specs, but right for real DOS/Windows
  41:Core/FatFs/Src/ff.c **** #define MAX_FAT16	0xFFF5			/* Max FAT16 clusters (differs from specs, but right for real DOS/Window
  42:Core/FatFs/Src/ff.c **** #define MAX_FAT32	0x0FFFFFF5		/* Max FAT32 clusters (not defined in specs, practical limit) */
  43:Core/FatFs/Src/ff.c **** #define MAX_EXFAT	0x7FFFFFFD		/* Max exFAT clusters (differs from specs, implementation limit) */
  44:Core/FatFs/Src/ff.c **** 
  45:Core/FatFs/Src/ff.c **** 
  46:Core/FatFs/Src/ff.c **** /* Character code support macros */
  47:Core/FatFs/Src/ff.c **** #define IsUpper(c)		((c) >= 'A' && (c) <= 'Z')
  48:Core/FatFs/Src/ff.c **** #define IsLower(c)		((c) >= 'a' && (c) <= 'z')
  49:Core/FatFs/Src/ff.c **** #define IsDigit(c)		((c) >= '0' && (c) <= '9')
  50:Core/FatFs/Src/ff.c **** #define IsSeparator(c)	((c) == '/' || (c) == '\\')
  51:Core/FatFs/Src/ff.c **** #define IsTerminator(c)	((UINT)(c) < (FF_USE_LFN ? ' ' : '!'))
  52:Core/FatFs/Src/ff.c **** #define IsSurrogate(c)	((c) >= 0xD800 && (c) <= 0xDFFF)
  53:Core/FatFs/Src/ff.c **** #define IsSurrogateH(c)	((c) >= 0xD800 && (c) <= 0xDBFF)
  54:Core/FatFs/Src/ff.c **** #define IsSurrogateL(c)	((c) >= 0xDC00 && (c) <= 0xDFFF)
  55:Core/FatFs/Src/ff.c **** 
  56:Core/FatFs/Src/ff.c **** 
  57:Core/FatFs/Src/ff.c **** /* Additional file access control and file status flags for internal use */
  58:Core/FatFs/Src/ff.c **** #define FA_SEEKEND	0x20	/* Seek to end of the file on file open */
  59:Core/FatFs/Src/ff.c **** #define FA_MODIFIED	0x40	/* File has been modified */
  60:Core/FatFs/Src/ff.c **** #define FA_DIRTY	0x80	/* FIL.buf[] needs to be written-back */
  61:Core/FatFs/Src/ff.c **** 
  62:Core/FatFs/Src/ff.c **** 
  63:Core/FatFs/Src/ff.c **** /* Additional file attribute bits for internal use */
  64:Core/FatFs/Src/ff.c **** #define AM_VOL		0x08	/* Volume label */
  65:Core/FatFs/Src/ff.c **** #define AM_LFN		0x0F	/* LFN entry */
  66:Core/FatFs/Src/ff.c **** #define AM_MASK		0x3F	/* Mask of defined bits in FAT */
  67:Core/FatFs/Src/ff.c **** #define AM_MASKX	0x37	/* Mask of defined bits in exFAT */
  68:Core/FatFs/Src/ff.c **** 
  69:Core/FatFs/Src/ff.c **** 
  70:Core/FatFs/Src/ff.c **** /* Name status flags in fn[11] */
  71:Core/FatFs/Src/ff.c **** #define NSFLAG		11		/* Index of the name status byte */
  72:Core/FatFs/Src/ff.c **** #define NS_LOSS		0x01	/* Out of 8.3 format */
  73:Core/FatFs/Src/ff.c **** #define NS_LFN		0x02	/* Force to create LFN entry */
  74:Core/FatFs/Src/ff.c **** #define NS_LAST		0x04	/* Last segment */
  75:Core/FatFs/Src/ff.c **** #define NS_BODY		0x08	/* Lower case flag (body) */
  76:Core/FatFs/Src/ff.c **** #define NS_EXT		0x10	/* Lower case flag (ext) */
  77:Core/FatFs/Src/ff.c **** #define NS_DOT		0x20	/* Dot entry */
  78:Core/FatFs/Src/ff.c **** #define NS_NOLFN	0x40	/* Do not find LFN */
  79:Core/FatFs/Src/ff.c **** #define NS_NONAME	0x80	/* Not followed */
  80:Core/FatFs/Src/ff.c **** 
  81:Core/FatFs/Src/ff.c **** 
  82:Core/FatFs/Src/ff.c **** /* exFAT directory entry types */
  83:Core/FatFs/Src/ff.c **** #define	ET_BITMAP	0x81	/* Allocation bitmap */
  84:Core/FatFs/Src/ff.c **** #define	ET_UPCASE	0x82	/* Up-case table */
  85:Core/FatFs/Src/ff.c **** #define	ET_VLABEL	0x83	/* Volume label */
  86:Core/FatFs/Src/ff.c **** #define	ET_FILEDIR	0x85	/* File and directory */
  87:Core/FatFs/Src/ff.c **** #define	ET_STREAM	0xC0	/* Stream extension */
  88:Core/FatFs/Src/ff.c **** #define	ET_FILENAME	0xC1	/* Name extension */
