7030:Core/FatFs/Src/ff.c **** 				digit = (int)(val / w); val -= digit * w;
7031:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + digit);	/* Put the digit */
7032:Core/FatFs/Src/ff.c **** 			} while (--mag >= -prec);		/* Output all digits specified by prec */
7033:Core/FatFs/Src/ff.c **** 			if (fmt != 'f') {	/* Put exponent if needed */
7034:Core/FatFs/Src/ff.c **** 				*buf++ = (char)fmt;
7035:Core/FatFs/Src/ff.c **** 				if (exp < 0) {
7036:Core/FatFs/Src/ff.c **** 					exp = 0 - exp; *buf++ = '-';
7037:Core/FatFs/Src/ff.c **** 				} else {
7038:Core/FatFs/Src/ff.c **** 					*buf++ = '+';
7039:Core/FatFs/Src/ff.c **** 				}
7040:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + exp / 10);
