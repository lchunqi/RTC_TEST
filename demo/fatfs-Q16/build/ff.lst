4978:Core/FatFs/Src/ff.c **** 				if (fs->fs_type == FS_EXFAT) {	/* exFAT: Scan allocation bitmap */
4979:Core/FatFs/Src/ff.c **** 					BYTE bm;
4980:Core/FatFs/Src/ff.c **** 					UINT b;
4981:Core/FatFs/Src/ff.c **** 
4982:Core/FatFs/Src/ff.c **** 					clst = fs->n_fatent - 2;	/* Number of clusters */
4983:Core/FatFs/Src/ff.c **** 					sect = fs->bitbase;			/* Bitmap sector */
4984:Core/FatFs/Src/ff.c **** 					i = 0;						/* Offset in the sector */
4985:Core/FatFs/Src/ff.c **** 					do {	/* Counts numbuer of clear bits (free clusters) in the bitmap */
4986:Core/FatFs/Src/ff.c **** 						if (i == 0) {	/* New sector? */
4987:Core/FatFs/Src/ff.c **** 							res = move_window(fs, sect++);
4988:Core/FatFs/Src/ff.c **** 							if (res != FR_OK) break;
4989:Core/FatFs/Src/ff.c **** 						}
4990:Core/FatFs/Src/ff.c **** 						for (b = 8, bm = ~fs->win[i]; b && clst; b--, clst--) {	/* Count clear bits in a byte */
4991:Core/FatFs/Src/ff.c **** 							nfree += bm & 1;
4992:Core/FatFs/Src/ff.c **** 							bm >>= 1;
4993:Core/FatFs/Src/ff.c **** 						}
4994:Core/FatFs/Src/ff.c **** 						i = (i + 1) % SS(fs);	/* Next byte */
4995:Core/FatFs/Src/ff.c **** 					} while (clst);
4996:Core/FatFs/Src/ff.c **** 				} else
4997:Core/FatFs/Src/ff.c **** #endif
4998:Core/FatFs/Src/ff.c **** 				{	/* FAT16/32: Scan WORD/DWORD FAT entries */
4999:Core/FatFs/Src/ff.c **** 					clst = fs->n_fatent;	/* Number of entries */
5000:Core/FatFs/Src/ff.c **** 					sect = fs->fatbase;		/* Top of the FAT */
5001:Core/FatFs/Src/ff.c **** 					i = 0;					/* Offset in the sector */
5002:Core/FatFs/Src/ff.c **** 					do {	/* Counts numbuer of entries with zero in the FAT */
5003:Core/FatFs/Src/ff.c **** 						if (i == 0) {	/* New sector? */
5004:Core/FatFs/Src/ff.c **** 							res = move_window(fs, sect++);
5005:Core/FatFs/Src/ff.c **** 							if (res != FR_OK) break;
5006:Core/FatFs/Src/ff.c **** 						}
5007:Core/FatFs/Src/ff.c **** 						if (fs->fs_type == FS_FAT16) {
5008:Core/FatFs/Src/ff.c **** 							if (ld_16(fs->win + i) == 0) nfree++;	/* FAT16: Is this cluster free? */
5009:Core/FatFs/Src/ff.c **** 							i += 2;	/* Next entry */
5010:Core/FatFs/Src/ff.c **** 						} else {
