3331:Core/FatFs/Src/ff.c **** 	if (ld_32(gpth + GPTH_PtNum) > 128) return 0;			/* Table size (must be 128 entries or less) */
3332:Core/FatFs/Src/ff.c **** 
3333:Core/FatFs/Src/ff.c **** 	return 1;
3334:Core/FatFs/Src/ff.c **** }
