3808:Core/FatFs/Src/ff.c **** 	DEF_NAMEBUFF
3809:Core/FatFs/Src/ff.c **** 
3810:Core/FatFs/Src/ff.c **** 
3811:Core/FatFs/Src/ff.c **** 	if (!fp) return FR_INVALID_OBJECT;	/* Reject null pointer */
3812:Core/FatFs/Src/ff.c **** 
3813:Core/FatFs/Src/ff.c **** 	/* Get logical drive number and mount the volume if needed */
3814:Core/FatFs/Src/ff.c **** 	mode &= FF_FS_READONLY ? FA_READ : FA_READ | FA_WRITE | FA_CREATE_ALWAYS | FA_CREATE_NEW | FA_OPEN
3815:Core/FatFs/Src/ff.c **** 	res = mount_volume(&path, &fs, mode);
3816:Core/FatFs/Src/ff.c **** 
3817:Core/FatFs/Src/ff.c **** 	if (res == FR_OK) {
3818:Core/FatFs/Src/ff.c **** 		fp->obj.fs = fs;
3819:Core/FatFs/Src/ff.c **** 		dj.obj.fs = fs;
3820:Core/FatFs/Src/ff.c **** 		INIT_NAMEBUFF(fs);
3821:Core/FatFs/Src/ff.c **** 		res = follow_path(&dj, path);	/* Follow the file path */
3822:Core/FatFs/Src/ff.c **** #if !FF_FS_READONLY	/* Read/Write configuration */
3823:Core/FatFs/Src/ff.c **** 		if (res == FR_OK) {
3824:Core/FatFs/Src/ff.c **** 			if (dj.fn[NSFLAG] & NS_NONAME) {	/* Origin directory itself? */
3825:Core/FatFs/Src/ff.c **** 				res = FR_INVALID_NAME;
3826:Core/FatFs/Src/ff.c **** 			}
3827:Core/FatFs/Src/ff.c **** #if FF_FS_LOCK
3828:Core/FatFs/Src/ff.c **** 			else {
3829:Core/FatFs/Src/ff.c **** 				res = chk_share(&dj, (mode & ~FA_READ) ? 1 : 0);	/* Check if the file can be used */
3830:Core/FatFs/Src/ff.c **** 			}
3831:Core/FatFs/Src/ff.c **** #endif
