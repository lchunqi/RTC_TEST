7041:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + exp % 10);
7042:Core/FatFs/Src/ff.c **** 			}
7043:Core/FatFs/Src/ff.c **** 		}
7044:Core/FatFs/Src/ff.c **** 	}
7045:Core/FatFs/Src/ff.c **** 	if (er) {	/* Error condition */
7046:Core/FatFs/Src/ff.c **** 		if (sign) *buf++ = sign;		/* Add sign if needed */
7047:Core/FatFs/Src/ff.c **** 		do {		/* Put error symbol */
