6870:Core/FatFs/Src/ff.c **** 
6871:Core/FatFs/Src/ff.c **** static int putc_flush (putbuff* pb)
6872:Core/FatFs/Src/ff.c **** {
6873:Core/FatFs/Src/ff.c **** 	UINT nw;
6874:Core/FatFs/Src/ff.c **** 
6875:Core/FatFs/Src/ff.c **** 	if (   pb->idx >= 0	/* Flush buffered characters to the file */
6876:Core/FatFs/Src/ff.c **** 		&& f_write(pb->fp, pb->buf, (UINT)pb->idx, &nw) == FR_OK
6877:Core/FatFs/Src/ff.c **** 		&& (UINT)pb->idx == nw) {
6878:Core/FatFs/Src/ff.c **** 		return pb->nchr;
6879:Core/FatFs/Src/ff.c **** 	}
6880:Core/FatFs/Src/ff.c **** 	return -1;
6881:Core/FatFs/Src/ff.c **** }
