5013:Core/FatFs/Src/ff.c **** 						}
5014:Core/FatFs/Src/ff.c **** 						i %= SS(fs);
5015:Core/FatFs/Src/ff.c **** 					} while (--clst);
5016:Core/FatFs/Src/ff.c **** 				}
5017:Core/FatFs/Src/ff.c **** 			}
5018:Core/FatFs/Src/ff.c **** 			if (res == FR_OK) {		/* Update parameters if succeeded */
5019:Core/FatFs/Src/ff.c **** 				*nclst = nfree;			/* Return the free clusters */
5020:Core/FatFs/Src/ff.c **** 				fs->free_clst = nfree;	/* Now free cluster count is valid */
5021:Core/FatFs/Src/ff.c **** 				fs->fsi_flag |= 1;		/* FAT32/exfAT : Allocation information is to be updated */
5022:Core/FatFs/Src/ff.c **** 			}
5023:Core/FatFs/Src/ff.c **** 		}
5024:Core/FatFs/Src/ff.c **** 	}
5025:Core/FatFs/Src/ff.c **** 
5026:Core/FatFs/Src/ff.c **** 	LEAVE_FF(fs, res);
5027:Core/FatFs/Src/ff.c **** }
