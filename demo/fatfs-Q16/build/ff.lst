6993:Core/FatFs/Src/ff.c **** 
6994:Core/FatFs/Src/ff.c **** 
6995:Core/FatFs/Src/ff.c **** 	if (isnan(val)) {			/* Not a number? */
6996:Core/FatFs/Src/ff.c **** 		er = "NaN";
6997:Core/FatFs/Src/ff.c **** 	} else {
6998:Core/FatFs/Src/ff.c **** 		if (prec < 0) prec = 6;	/* Default precision? (6 fractional digits) */
6999:Core/FatFs/Src/ff.c **** 		if (val < 0) {			/* Negative? */
7000:Core/FatFs/Src/ff.c **** 			val = 0 - val; sign = '-';
7001:Core/FatFs/Src/ff.c **** 		} else {
7002:Core/FatFs/Src/ff.c **** 			sign = '+';
7003:Core/FatFs/Src/ff.c **** 		}
7004:Core/FatFs/Src/ff.c **** 		if (isinf(val)) {		/* Infinite? */
7005:Core/FatFs/Src/ff.c **** 			er = "INF";
7006:Core/FatFs/Src/ff.c **** 		} else {
