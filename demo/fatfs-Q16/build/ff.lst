3324:Core/FatFs/Src/ff.c **** 	hlen = ld_32(gpth + GPTH_Size);							/* Check header size */
3325:Core/FatFs/Src/ff.c **** 	if (hlen < 92 || hlen > FF_MIN_SS) return 0;
3326:Core/FatFs/Src/ff.c **** 	for (i = 0, bcc = 0xFFFFFFFF; i < hlen; i++) {			/* Check header BCC */
3327:Core/FatFs/Src/ff.c **** 		bcc = crc32(bcc, i - GPTH_Bcc < 4 ? 0 : gpth[i]);
3328:Core/FatFs/Src/ff.c **** 	}
3329:Core/FatFs/Src/ff.c **** 	if (~bcc != ld_32(gpth + GPTH_Bcc)) return 0;
