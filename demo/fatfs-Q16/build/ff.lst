3832:Core/FatFs/Src/ff.c **** 		}
3833:Core/FatFs/Src/ff.c **** 		/* Create or Open a file */
3834:Core/FatFs/Src/ff.c **** 		if (mode & (FA_CREATE_ALWAYS | FA_OPEN_ALWAYS | FA_CREATE_NEW)) {
3835:Core/FatFs/Src/ff.c **** 			if (res != FR_OK) {					/* No file, create new */
3836:Core/FatFs/Src/ff.c **** 				if (res == FR_NO_FILE) {		/* There is no file to open, create a new entry */
3837:Core/FatFs/Src/ff.c **** #if FF_FS_LOCK
3838:Core/FatFs/Src/ff.c **** 					res = enq_share() ? dir_register(&dj) : FR_TOO_MANY_OPEN_FILES;
3839:Core/FatFs/Src/ff.c **** #else
3840:Core/FatFs/Src/ff.c **** 					res = dir_register(&dj);
3841:Core/FatFs/Src/ff.c **** #endif
3842:Core/FatFs/Src/ff.c **** 				}
3843:Core/FatFs/Src/ff.c **** 				mode |= FA_CREATE_ALWAYS;		/* File is created */
3844:Core/FatFs/Src/ff.c **** 			}
3845:Core/FatFs/Src/ff.c **** 			else {								/* An object with the same name is already existing */
3846:Core/FatFs/Src/ff.c **** 				if (mode & FA_CREATE_NEW) {
