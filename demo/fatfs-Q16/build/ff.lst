3796:Core/FatFs/Src/ff.c **** /* API: Open or Create a File                                            */
3797:Core/FatFs/Src/ff.c **** /*-----------------------------------------------------------------------*/
3798:Core/FatFs/Src/ff.c **** 
3799:Core/FatFs/Src/ff.c **** FRESULT f_open (
3800:Core/FatFs/Src/ff.c **** 	FIL* fp,			/* Pointer to the blank file object */
3801:Core/FatFs/Src/ff.c **** 	const TCHAR* path,	/* Pointer to the file name */
3802:Core/FatFs/Src/ff.c **** 	BYTE mode			/* Access mode and open mode flags */
3803:Core/FatFs/Src/ff.c **** )
3804:Core/FatFs/Src/ff.c **** {
3805:Core/FatFs/Src/ff.c **** 	FRESULT res;
