3736:Core/FatFs/Src/ff.c **** /* API: Mount/Unmount a Logical Drive                                    */
3737:Core/FatFs/Src/ff.c **** /*-----------------------------------------------------------------------*/
3738:Core/FatFs/Src/ff.c **** 
3739:Core/FatFs/Src/ff.c **** FRESULT f_mount (
3740:Core/FatFs/Src/ff.c **** 	FATFS* fs,			/* Pointer to the filesystem object to be registered (NULL:unmount)*/
3741:Core/FatFs/Src/ff.c **** 	const TCHAR* path,	/* Logical drive number to be mounted/unmounted */
3742:Core/FatFs/Src/ff.c **** 	BYTE opt			/* Mount option: 0=Do not mount (delayed mount), 1=Mount immediately */
3743:Core/FatFs/Src/ff.c **** )
3744:Core/FatFs/Src/ff.c **** {
3745:Core/FatFs/Src/ff.c **** 	FATFS *cfs;
3746:Core/FatFs/Src/ff.c **** 	int vol;
3747:Core/FatFs/Src/ff.c **** 	FRESULT res;
3748:Core/FatFs/Src/ff.c **** 	const TCHAR *rp = path;
3749:Core/FatFs/Src/ff.c **** 
3750:Core/FatFs/Src/ff.c **** 
3751:Core/FatFs/Src/ff.c **** 	/* Get volume ID (logical drive number) */
3752:Core/FatFs/Src/ff.c **** 	vol = get_ldnumber(&rp);
3753:Core/FatFs/Src/ff.c **** 	if (vol < 0) return FR_INVALID_DRIVE;
3754:Core/FatFs/Src/ff.c **** 
3755:Core/FatFs/Src/ff.c **** 	cfs = FatFs[vol];			/* Pointer to the filesystem object of the volume */
3756:Core/FatFs/Src/ff.c **** 	if (cfs) {					/* Unregister current filesystem object */
3757:Core/FatFs/Src/ff.c **** 		FatFs[vol] = 0;
3758:Core/FatFs/Src/ff.c **** #if FF_FS_LOCK					/* Clear file lock semaphores correspond to this volume */
3759:Core/FatFs/Src/ff.c **** 		clear_share(cfs);
3760:Core/FatFs/Src/ff.c **** #endif
3761:Core/FatFs/Src/ff.c **** #if FF_FS_REENTRANT				/* Discard mutex of the current volume */
3762:Core/FatFs/Src/ff.c **** 		ff_mutex_delete(vol);
3763:Core/FatFs/Src/ff.c **** #endif
3764:Core/FatFs/Src/ff.c **** 		cfs->fs_type = 0;		/* Invalidate the filesystem object to be unregistered */
3765:Core/FatFs/Src/ff.c **** 	}
3766:Core/FatFs/Src/ff.c **** 
3767:Core/FatFs/Src/ff.c **** 	if (fs) {					/* Register new filesystem object */
3768:Core/FatFs/Src/ff.c **** 		fs->pdrv = LD2PD(vol);	/* Volume hosting physical drive */
3769:Core/FatFs/Src/ff.c **** #if FF_FS_REENTRANT				/* Create a volume mutex */
3770:Core/FatFs/Src/ff.c **** 		fs->ldrv = (BYTE)vol;	/* Owner volume ID */
3771:Core/FatFs/Src/ff.c **** 		if (!ff_mutex_create(vol)) return FR_INT_ERR;
3772:Core/FatFs/Src/ff.c **** #if FF_FS_LOCK
3773:Core/FatFs/Src/ff.c **** 		if (SysLock == 0) {		/* Create a system mutex if needed */
3774:Core/FatFs/Src/ff.c **** 			if (!ff_mutex_create(FF_VOLUMES)) {
ARM GAS  C:\Users\84759\AppData\Local\Temp\cc0twHqK.s 			page 167


3775:Core/FatFs/Src/ff.c **** 				ff_mutex_delete(vol);
3776:Core/FatFs/Src/ff.c **** 				return FR_INT_ERR;
3777:Core/FatFs/Src/ff.c **** 			}
3778:Core/FatFs/Src/ff.c **** 			SysLock = 1;		/* System mutex is ready */
3779:Core/FatFs/Src/ff.c **** 		}
3780:Core/FatFs/Src/ff.c **** #endif
3781:Core/FatFs/Src/ff.c **** #endif
3782:Core/FatFs/Src/ff.c **** 		fs->fs_type = 0;		/* Invalidate the new filesystem object */
3783:Core/FatFs/Src/ff.c **** 		FatFs[vol] = fs;		/* Register it */
3784:Core/FatFs/Src/ff.c **** 	}
3785:Core/FatFs/Src/ff.c **** 
3786:Core/FatFs/Src/ff.c **** 	if (opt == 0) return FR_OK;	/* Do not mount now, it will be mounted in subsequent file functions *
3787:Core/FatFs/Src/ff.c **** 
3788:Core/FatFs/Src/ff.c **** 	res = mount_volume(&path, &fs, 0);	/* Force mounted the volume in this function */
3789:Core/FatFs/Src/ff.c **** 	LEAVE_FF(fs, res);
3790:Core/FatFs/Src/ff.c **** }
