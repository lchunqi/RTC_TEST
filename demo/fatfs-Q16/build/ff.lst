3296:Core/FatFs/Src/ff.c **** 
3297:Core/FatFs/Src/ff.c **** static DWORD crc32 (	/* Returns next CRC value */
3298:Core/FatFs/Src/ff.c **** 	DWORD crc,			/* Current CRC value */
3299:Core/FatFs/Src/ff.c **** 	BYTE d				/* A byte to be processed */
3300:Core/FatFs/Src/ff.c **** )
3301:Core/FatFs/Src/ff.c **** {
3302:Core/FatFs/Src/ff.c **** 	BYTE b;
3303:Core/FatFs/Src/ff.c **** 
3304:Core/FatFs/Src/ff.c **** 
3305:Core/FatFs/Src/ff.c **** 	for (b = 1; b; b <<= 1) {
3306:Core/FatFs/Src/ff.c **** 		crc ^= (d & b) ? 1 : 0;
3307:Core/FatFs/Src/ff.c **** 		crc = (crc & 1) ? crc >> 1 ^ 0xEDB88320 : crc >> 1;
3308:Core/FatFs/Src/ff.c **** 	}
3309:Core/FatFs/Src/ff.c **** 	return crc;
3310:Core/FatFs/Src/ff.c **** }
