            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "STM32F103xE"
               
            ],
            
            "cStandard": "c99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm",
            "configurationProvider": "ms-vscode.makefile-tools"
        }
    ],
    "version": 4
