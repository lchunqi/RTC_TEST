2092:Core/FatFs/Src/ff.c **** static WORD xdir_sum (	/* Get checksum of the directoly entry block */
2093:Core/FatFs/Src/ff.c **** 	const BYTE* dir		/* Directory entry block to be calculated */
2094:Core/FatFs/Src/ff.c **** )
2095:Core/FatFs/Src/ff.c **** {
2096:Core/FatFs/Src/ff.c **** 	UINT i, szblk;
