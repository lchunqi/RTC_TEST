2098:Core/FatFs/Src/ff.c **** 
2099:Core/FatFs/Src/ff.c **** 
2100:Core/FatFs/Src/ff.c **** 	szblk = ((UINT)dir[XDIR_NumSec] + 1) * SZDIRE;	/* Number of bytes of the entry block */
2101:Core/FatFs/Src/ff.c **** 	for (i = sum = 0; i < szblk; i++) {
