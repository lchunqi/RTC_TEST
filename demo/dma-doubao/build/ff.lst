1794:Core/FatFs/Src/ff.c **** 					if (clst == 0) return FR_DENIED;			/* No free cluster */
1795:Core/FatFs/Src/ff.c **** 					if (clst == 1) return FR_INT_ERR;			/* Internal error */
1796:Core/FatFs/Src/ff.c **** 					if (clst == 0xFFFFFFFF) return FR_DISK_ERR;	/* Disk error */
1797:Core/FatFs/Src/ff.c **** 					if (dir_clear(fs, clst) != FR_OK) return FR_DISK_ERR;	/* Clean up the stretched table */
1798:Core/FatFs/Src/ff.c **** 					if (FF_FS_EXFAT) dp->obj.stat |= 4;			/* exFAT: The directory has been stretched */
1799:Core/FatFs/Src/ff.c **** #else
1800:Core/FatFs/Src/ff.c **** 					if (!stretch) dp->sect = 0;					/* (this line is to suppress compiler warning) */
1801:Core/FatFs/Src/ff.c **** 					dp->sect = 0; return FR_NO_FILE;			/* Report EOT */
1802:Core/FatFs/Src/ff.c **** #endif
1803:Core/FatFs/Src/ff.c **** 				}
1804:Core/FatFs/Src/ff.c **** 				dp->clust = clst;		/* Initialize data for new cluster */
