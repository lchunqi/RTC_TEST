2009:Core/FatFs/Src/ff.c **** /*-----------------------------------------------------------------------*/
2010:Core/FatFs/Src/ff.c **** /* FAT-LFN: Create a Numbered SFN                                        */
2011:Core/FatFs/Src/ff.c **** /*-----------------------------------------------------------------------*/
2012:Core/FatFs/Src/ff.c **** 
2013:Core/FatFs/Src/ff.c **** static void gen_numname (
2014:Core/FatFs/Src/ff.c **** 	BYTE* dst,			/* Pointer to the buffer to store numbered SFN */
2015:Core/FatFs/Src/ff.c **** 	const BYTE* src,	/* Pointer to SFN in directory form */
2016:Core/FatFs/Src/ff.c **** 	const WCHAR* lfn,	/* Pointer to LFN */
2017:Core/FatFs/Src/ff.c **** 	WORD seq			/* Sequence number */
2018:Core/FatFs/Src/ff.c **** )
2019:Core/FatFs/Src/ff.c **** {
2020:Core/FatFs/Src/ff.c **** 	BYTE ns[8], c;
2021:Core/FatFs/Src/ff.c **** 	UINT i, j;
2022:Core/FatFs/Src/ff.c **** 
2023:Core/FatFs/Src/ff.c **** 
2024:Core/FatFs/Src/ff.c **** 	memcpy(dst, src, 11);	/* Prepare the SFN to be modified */
2025:Core/FatFs/Src/ff.c **** 
2026:Core/FatFs/Src/ff.c **** 	if (seq > 5) {	/* In case of many collisions, generate a hash number instead of sequential number 
2027:Core/FatFs/Src/ff.c **** 		WCHAR wc;
2028:Core/FatFs/Src/ff.c **** 		DWORD crc_sreg = seq;
2029:Core/FatFs/Src/ff.c **** 
2030:Core/FatFs/Src/ff.c **** 		while (*lfn) {	/* Create a CRC value as a hash of LFN */
2031:Core/FatFs/Src/ff.c **** 			wc = *lfn++;
2032:Core/FatFs/Src/ff.c **** 			for (i = 0; i < 16; i++) {
2033:Core/FatFs/Src/ff.c **** 				crc_sreg = (crc_sreg << 1) + (wc & 1);
2034:Core/FatFs/Src/ff.c **** 				wc >>= 1;
2035:Core/FatFs/Src/ff.c **** 				if (crc_sreg & 0x10000) crc_sreg ^= 0x11021;
2036:Core/FatFs/Src/ff.c **** 			}
2037:Core/FatFs/Src/ff.c **** 		}
2038:Core/FatFs/Src/ff.c **** 		seq = (WORD)crc_sreg;
2039:Core/FatFs/Src/ff.c **** 	}
2040:Core/FatFs/Src/ff.c **** 
2041:Core/FatFs/Src/ff.c **** 	/* Make suffix (~ + 4-digit hexadecimal) */
2042:Core/FatFs/Src/ff.c **** 	i = 7;
2043:Core/FatFs/Src/ff.c **** 	do {
2044:Core/FatFs/Src/ff.c **** 		c = (BYTE)((seq % 16) + '0'); seq /= 16;
2045:Core/FatFs/Src/ff.c **** 		if (c > '9') c += 7;
2046:Core/FatFs/Src/ff.c **** 		ns[i--] = c;
2047:Core/FatFs/Src/ff.c **** 	} while (i && seq);
2048:Core/FatFs/Src/ff.c **** 	ns[i] = '~';
2049:Core/FatFs/Src/ff.c **** 
2050:Core/FatFs/Src/ff.c **** 	/* Append the suffix to the SFN body */
2051:Core/FatFs/Src/ff.c **** 	for (j = 0; j < i && dst[j] != ' '; j++) {	/* Find the offset to append */
2052:Core/FatFs/Src/ff.c **** 		if (dbc_1st(dst[j])) {	/* To avoid DBC break up */
2053:Core/FatFs/Src/ff.c **** 			if (j == i - 1) break;
2054:Core/FatFs/Src/ff.c **** 			j++;
2055:Core/FatFs/Src/ff.c **** 		}
2056:Core/FatFs/Src/ff.c **** 	}
2057:Core/FatFs/Src/ff.c **** 	do {	/* Append the suffix */
2058:Core/FatFs/Src/ff.c **** 		dst[j++] = (i < 8) ? ns[i++] : ' ';
2059:Core/FatFs/Src/ff.c **** 	} while (j < 8);
