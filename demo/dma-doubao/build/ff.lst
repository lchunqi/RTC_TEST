1371:Core/FatFs/Src/ff.c **** 	clst -= 2;	/* The first bit corresponds to cluster #2 */
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccKSSW7O.s 			page 31


1372:Core/FatFs/Src/ff.c **** 	sect = fs->bitbase + clst / 8 / SS(fs);	/* Sector address */
1373:Core/FatFs/Src/ff.c **** 	i = clst / 8 % SS(fs);					/* Byte offset in the sector */
1374:Core/FatFs/Src/ff.c **** 	bm = 1 << (clst % 8);					/* Bit mask in the byte */
1375:Core/FatFs/Src/ff.c **** 	for (;;) {
1376:Core/FatFs/Src/ff.c **** 		if (move_window(fs, sect++) != FR_OK) return FR_DISK_ERR;
1377:Core/FatFs/Src/ff.c **** 		do {
1378:Core/FatFs/Src/ff.c **** 			do {
1379:Core/FatFs/Src/ff.c **** 				if (bv == (int)((fs->win[i] & bm) != 0)) return FR_INT_ERR;	/* Is the bit expected value? */
1380:Core/FatFs/Src/ff.c **** 				fs->win[i] ^= bm;	/* Flip the bit */
1381:Core/FatFs/Src/ff.c **** 				fs->wflag = 1;
1382:Core/FatFs/Src/ff.c **** 				if (--ncl == 0) return FR_OK;	/* All bits processed? */
1383:Core/FatFs/Src/ff.c **** 			} while (bm <<= 1);		/* Next bit */
1384:Core/FatFs/Src/ff.c **** 			bm = 1;
1385:Core/FatFs/Src/ff.c **** 		} while (++i < SS(fs));		/* Next byte */
1386:Core/FatFs/Src/ff.c **** 		i = 0;
1387:Core/FatFs/Src/ff.c **** 	}
1388:Core/FatFs/Src/ff.c **** }
