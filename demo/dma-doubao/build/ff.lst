6980:Core/FatFs/Src/ff.c **** static void ftoa (
6981:Core/FatFs/Src/ff.c **** 	char* buf,	/* Buffer to output the floating point string */
6982:Core/FatFs/Src/ff.c **** 	double val,	/* Value to output */
6983:Core/FatFs/Src/ff.c **** 	int prec,	/* Number of fractional digits */
6984:Core/FatFs/Src/ff.c **** 	TCHAR fmt	/* Notation */
6985:Core/FatFs/Src/ff.c **** )
6986:Core/FatFs/Src/ff.c **** {
6987:Core/FatFs/Src/ff.c **** 	int digit;
6988:Core/FatFs/Src/ff.c **** 	int exp = 0, mag = 0;
6989:Core/FatFs/Src/ff.c **** 	char sign = 0;
6990:Core/FatFs/Src/ff.c **** 	double w;
6991:Core/FatFs/Src/ff.c **** 	const char *er = 0;
6992:Core/FatFs/Src/ff.c **** 	const char ds = FF_PRINT_FLOAT == 2 ? ',' : '.';
6993:Core/FatFs/Src/ff.c **** 
6994:Core/FatFs/Src/ff.c **** 
6995:Core/FatFs/Src/ff.c **** 	if (isnan(val)) {			/* Not a number? */
6996:Core/FatFs/Src/ff.c **** 		er = "NaN";
6997:Core/FatFs/Src/ff.c **** 	} else {
6998:Core/FatFs/Src/ff.c **** 		if (prec < 0) prec = 6;	/* Default precision? (6 fractional digits) */
6999:Core/FatFs/Src/ff.c **** 		if (val < 0) {			/* Negative? */
7000:Core/FatFs/Src/ff.c **** 			val = 0 - val; sign = '-';
7001:Core/FatFs/Src/ff.c **** 		} else {
7002:Core/FatFs/Src/ff.c **** 			sign = '+';
7003:Core/FatFs/Src/ff.c **** 		}
7004:Core/FatFs/Src/ff.c **** 		if (isinf(val)) {		/* Infinite? */
7005:Core/FatFs/Src/ff.c **** 			er = "INF";
7006:Core/FatFs/Src/ff.c **** 		} else {
7007:Core/FatFs/Src/ff.c **** 			if (fmt == 'f') {	/* Decimal notation? */
7008:Core/FatFs/Src/ff.c **** 				val += i10x(0 - prec) / 2;	/* Round (nearest) */
7009:Core/FatFs/Src/ff.c **** 				mag = ilog10(val);
7010:Core/FatFs/Src/ff.c **** 				if (mag < 0) mag = 0;
7011:Core/FatFs/Src/ff.c **** 				if (mag + prec + 3 >= SZ_NUM_BUF) er = "OV";	/* Buffer overflow? */
7012:Core/FatFs/Src/ff.c **** 			} else {			/* E notation */
7013:Core/FatFs/Src/ff.c **** 				if (val != 0) {		/* Not a true zero? */
7014:Core/FatFs/Src/ff.c **** 					val += i10x(ilog10(val) - prec) / 2;	/* Round (nearest) */
7015:Core/FatFs/Src/ff.c **** 					exp = ilog10(val);
7016:Core/FatFs/Src/ff.c **** 					if (exp > 99 || prec + 7 >= SZ_NUM_BUF) {	/* Buffer overflow or E > +99? */
7017:Core/FatFs/Src/ff.c **** 						er = "OV";
7018:Core/FatFs/Src/ff.c **** 					} else {
7019:Core/FatFs/Src/ff.c **** 						if (exp < -99) exp = -99;
7020:Core/FatFs/Src/ff.c **** 						val /= i10x(exp);	/* Normalize */
7021:Core/FatFs/Src/ff.c **** 					}
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccKSSW7O.s 			page 412


7022:Core/FatFs/Src/ff.c **** 				}
7023:Core/FatFs/Src/ff.c **** 			}
7024:Core/FatFs/Src/ff.c **** 		}
7025:Core/FatFs/Src/ff.c **** 		if (!er) {	/* Not error condition */
7026:Core/FatFs/Src/ff.c **** 			if (sign == '-') *buf++ = sign;	/* Add a - if negative value */
7027:Core/FatFs/Src/ff.c **** 			do {				/* Put decimal number */
7028:Core/FatFs/Src/ff.c **** 				if (mag == -1) *buf++ = ds;	/* Insert a decimal separator when get into fractional part */
7029:Core/FatFs/Src/ff.c **** 				w = i10x(mag);				/* Snip the highest digit d */
7030:Core/FatFs/Src/ff.c **** 				digit = (int)(val / w); val -= digit * w;
7031:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + digit);	/* Put the digit */
7032:Core/FatFs/Src/ff.c **** 			} while (--mag >= -prec);		/* Output all digits specified by prec */
7033:Core/FatFs/Src/ff.c **** 			if (fmt != 'f') {	/* Put exponent if needed */
7034:Core/FatFs/Src/ff.c **** 				*buf++ = (char)fmt;
7035:Core/FatFs/Src/ff.c **** 				if (exp < 0) {
7036:Core/FatFs/Src/ff.c **** 					exp = 0 - exp; *buf++ = '-';
7037:Core/FatFs/Src/ff.c **** 				} else {
7038:Core/FatFs/Src/ff.c **** 					*buf++ = '+';
7039:Core/FatFs/Src/ff.c **** 				}
7040:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + exp / 10);
7041:Core/FatFs/Src/ff.c **** 				*buf++ = (char)('0' + exp % 10);
7042:Core/FatFs/Src/ff.c **** 			}
7043:Core/FatFs/Src/ff.c **** 		}
7044:Core/FatFs/Src/ff.c **** 	}
7045:Core/FatFs/Src/ff.c **** 	if (er) {	/* Error condition */
7046:Core/FatFs/Src/ff.c **** 		if (sign) *buf++ = sign;		/* Add sign if needed */
7047:Core/FatFs/Src/ff.c **** 		do {		/* Put error symbol */
7048:Core/FatFs/Src/ff.c **** 			*buf++ = *er++;
7049:Core/FatFs/Src/ff.c **** 		} while (*er);
7050:Core/FatFs/Src/ff.c **** 	}
7051:Core/FatFs/Src/ff.c **** 	*buf = 0;	/* Term */
7052:Core/FatFs/Src/ff.c **** }
7053:Core/FatFs/Src/ff.c **** #endif	/* FF_PRINT_FLOAT && FF_INTDEF == 2 */
