6936:Core/FatFs/Src/ff.c **** static int ilog10 (double n)	/* Calculate log10(n) in integer output */
6937:Core/FatFs/Src/ff.c **** {
6938:Core/FatFs/Src/ff.c **** 	int rv = 0;
6939:Core/FatFs/Src/ff.c **** 
6940:Core/FatFs/Src/ff.c **** 	while (n >= 10) {	/* Decimate digit in right shift */
6941:Core/FatFs/Src/ff.c **** 		if (n >= 100000) {
6942:Core/FatFs/Src/ff.c **** 			n /= 100000; rv += 5;
6943:Core/FatFs/Src/ff.c **** 		} else {
6944:Core/FatFs/Src/ff.c **** 			n /= 10; rv++;
6945:Core/FatFs/Src/ff.c **** 		}
6946:Core/FatFs/Src/ff.c **** 	}
6947:Core/FatFs/Src/ff.c **** 	while (n < 1) {		/* Decimate digit in left shift */
6948:Core/FatFs/Src/ff.c **** 		if (n < 0.00001) {
6949:Core/FatFs/Src/ff.c **** 			n *= 100000; rv -= 5;
6950:Core/FatFs/Src/ff.c **** 		} else {
6951:Core/FatFs/Src/ff.c **** 			n *= 10; rv--;
6952:Core/FatFs/Src/ff.c **** 		}
6953:Core/FatFs/Src/ff.c **** 	}
6954:Core/FatFs/Src/ff.c **** 	return rv;
6955:Core/FatFs/Src/ff.c **** }
6956:Core/FatFs/Src/ff.c **** 
6957:Core/FatFs/Src/ff.c **** 
6958:Core/FatFs/Src/ff.c **** static double i10x (int n)	/* Calculate 10^n in integer input */
6959:Core/FatFs/Src/ff.c **** {
6960:Core/FatFs/Src/ff.c **** 	double rv = 1;
6961:Core/FatFs/Src/ff.c **** 
6962:Core/FatFs/Src/ff.c **** 	while (n > 0) {		/* Left shift */
6963:Core/FatFs/Src/ff.c **** 		if (n >= 5) {
6964:Core/FatFs/Src/ff.c **** 			rv *= 100000; n -= 5;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccKSSW7O.s 			page 411


6965:Core/FatFs/Src/ff.c **** 		} else {
6966:Core/FatFs/Src/ff.c **** 			rv *= 10; n--;
6967:Core/FatFs/Src/ff.c **** 		}
6968:Core/FatFs/Src/ff.c **** 	}
6969:Core/FatFs/Src/ff.c **** 	while (n < 0) {		/* Right shift */
6970:Core/FatFs/Src/ff.c **** 		if (n <= -5) {
6971:Core/FatFs/Src/ff.c **** 			rv /= 100000; n += 5;
6972:Core/FatFs/Src/ff.c **** 		} else {
6973:Core/FatFs/Src/ff.c **** 			rv /= 10; n++;
6974:Core/FatFs/Src/ff.c **** 		}
6975:Core/FatFs/Src/ff.c **** 	}
6976:Core/FatFs/Src/ff.c **** 	return rv;
6977:Core/FatFs/Src/ff.c **** }
