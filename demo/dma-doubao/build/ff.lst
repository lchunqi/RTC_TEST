1315:Core/FatFs/Src/ff.c **** /*--------------------------------------*/
1316:Core/FatFs/Src/ff.c **** /* Find a contiguous free cluster block */
1317:Core/FatFs/Src/ff.c **** /*--------------------------------------*/
1318:Core/FatFs/Src/ff.c **** 
1319:Core/FatFs/Src/ff.c **** static DWORD find_bitmap (	/* 0:Not found, 2..:Cluster block found, 0xFFFFFFFF:Disk error */
1320:Core/FatFs/Src/ff.c **** 	FATFS* fs,	/* Filesystem object */
1321:Core/FatFs/Src/ff.c **** 	DWORD clst,	/* Cluster number to scan from */
1322:Core/FatFs/Src/ff.c **** 	DWORD ncl	/* Number of contiguous clusters to find (1..) */
1323:Core/FatFs/Src/ff.c **** )
1324:Core/FatFs/Src/ff.c **** {
1325:Core/FatFs/Src/ff.c **** 	BYTE bm, bv;
1326:Core/FatFs/Src/ff.c **** 	UINT i;
1327:Core/FatFs/Src/ff.c **** 	DWORD val, scl, ctr;
1328:Core/FatFs/Src/ff.c **** 
1329:Core/FatFs/Src/ff.c **** 
1330:Core/FatFs/Src/ff.c **** 	clst -= 2;	/* The first bit in the bitmap corresponds to cluster #2 */
1331:Core/FatFs/Src/ff.c **** 	if (clst >= fs->n_fatent - 2) clst = 0;
1332:Core/FatFs/Src/ff.c **** 	scl = val = clst; ctr = 0;
1333:Core/FatFs/Src/ff.c **** 	for (;;) {
1334:Core/FatFs/Src/ff.c **** 		if (move_window(fs, fs->bitbase + val / 8 / SS(fs)) != FR_OK) return 0xFFFFFFFF;
1335:Core/FatFs/Src/ff.c **** 		i = val / 8 % SS(fs); bm = 1 << (val % 8);
1336:Core/FatFs/Src/ff.c **** 		do {
1337:Core/FatFs/Src/ff.c **** 			do {
1338:Core/FatFs/Src/ff.c **** 				bv = fs->win[i] & bm; bm <<= 1;		/* Get bit value */
1339:Core/FatFs/Src/ff.c **** 				if (++val >= fs->n_fatent - 2) {	/* Next cluster (with wrap-around) */
1340:Core/FatFs/Src/ff.c **** 					val = 0; bm = 0; i = SS(fs);
1341:Core/FatFs/Src/ff.c **** 				}
1342:Core/FatFs/Src/ff.c **** 				if (bv == 0) {	/* Is it a free cluster? */
1343:Core/FatFs/Src/ff.c **** 					if (++ctr == ncl) return scl + 2;	/* Check if run length is sufficient for required */
1344:Core/FatFs/Src/ff.c **** 				} else {
1345:Core/FatFs/Src/ff.c **** 					scl = val; ctr = 0;		/* Encountered a cluster in-use, restart to scan */
1346:Core/FatFs/Src/ff.c **** 				}
1347:Core/FatFs/Src/ff.c **** 				if (val == clst) return 0;	/* All cluster scanned? */
1348:Core/FatFs/Src/ff.c **** 			} while (bm != 0);
1349:Core/FatFs/Src/ff.c **** 			bm = 1;
1350:Core/FatFs/Src/ff.c **** 		} while (++i < SS(fs));
1351:Core/FatFs/Src/ff.c **** 	}
1352:Core/FatFs/Src/ff.c **** }
1353:Core/FatFs/Src/ff.c **** 
1354:Core/FatFs/Src/ff.c **** 
1355:Core/FatFs/Src/ff.c **** /*----------------------------------------*/
1356:Core/FatFs/Src/ff.c **** /* Set/Clear a block of allocation bitmap */
1357:Core/FatFs/Src/ff.c **** /*----------------------------------------*/
1358:Core/FatFs/Src/ff.c **** 
1359:Core/FatFs/Src/ff.c **** static FRESULT change_bitmap (
1360:Core/FatFs/Src/ff.c **** 	FATFS* fs,	/* Filesystem object */
1361:Core/FatFs/Src/ff.c **** 	DWORD clst,	/* Cluster number to change from */
1362:Core/FatFs/Src/ff.c **** 	DWORD ncl,	/* Number of clusters to be changed */
1363:Core/FatFs/Src/ff.c **** 	int bv		/* bit value to be set (0 or 1) */
1364:Core/FatFs/Src/ff.c **** )
1365:Core/FatFs/Src/ff.c **** {
1366:Core/FatFs/Src/ff.c **** 	BYTE bm;
1367:Core/FatFs/Src/ff.c **** 	UINT i;
1368:Core/FatFs/Src/ff.c **** 	LBA_t sect;
1369:Core/FatFs/Src/ff.c **** 
