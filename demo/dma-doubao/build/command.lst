  69:User/Src/command.c **** uint16_t CharToInt(char* source, uint8_t start, int* number)
  70:User/Src/command.c **** {
  71:User/Src/command.c **** 	uint16_t length;
  72:User/Src/command.c **** 	uint16_t i;
  73:User/Src/command.c **** 	int sum = 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccJrI7lo.s 			page 3


  74:User/Src/command.c **** 	int state = 0;
  75:User/Src/command.c **** 	uint8_t hex = 0;
  76:User/Src/command.c **** 	length = strlen(source);
  77:User/Src/command.c **** 	if (start >= length) {
  78:User/Src/command.c **** 		*number = 0;
  79:User/Src/command.c **** 		return 0;
  80:User/Src/command.c **** 	}
  81:User/Src/command.c **** 	if (source[start] == '-') {
  82:User/Src/command.c **** 		state = -1;
  83:User/Src/command.c **** 		start++;
  84:User/Src/command.c **** 	} else {
  85:User/Src/command.c **** 		state = 1;
  86:User/Src/command.c **** 		if (start + 1 < length ) {
  87:User/Src/command.c **** 			if (source[start] == '0' && (source[start + 1] == 'x' ||source[start + 1] == 'X')) {
  88:User/Src/command.c **** 				start += 2;
  89:User/Src/command.c **** 				hex = 1;
  90:User/Src/command.c **** 			}
  91:User/Src/command.c **** 		}
  92:User/Src/command.c **** 	}
  93:User/Src/command.c **** 	for (i = start; i < length; i++) {
  94:User/Src/command.c **** 		if (source[i] >= '0' && source[i] <= '9') {
  95:User/Src/command.c **** 			if (hex == 1) {
  96:User/Src/command.c **** 				sum = sum * 16 + source[i] - '0';
  97:User/Src/command.c **** 			} else {
  98:User/Src/command.c **** 				sum = sum * 10 + source[i] - '0';
  99:User/Src/command.c **** 			}
 100:User/Src/command.c **** 		} else if (source[i] >= 'a' && source[i] <= 'f') {
 101:User/Src/command.c **** 			if (hex == 1) {
 102:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'a' + 10;
 103:User/Src/command.c **** 			} else {
 104:User/Src/command.c **** 				*number = 0;
 105:User/Src/command.c **** 				return 0;
 106:User/Src/command.c **** 			}
 107:User/Src/command.c **** 		}else if (source[i] >= 'A' && source[i] <= 'F') {
 108:User/Src/command.c **** 			if (hex == 1) {
 109:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'A' + 10;
 110:User/Src/command.c **** 			} else {
 111:User/Src/command.c **** 				*number = 0;
 112:User/Src/command.c **** 				return 0;
 113:User/Src/command.c **** 			}
 114:User/Src/command.c **** 		} else if (source[i] == ' ' || source[i] == ',') {
 115:User/Src/command.c **** 			break;
 116:User/Src/command.c **** 		}
 117:User/Src/command.c **** 	}
 118:User/Src/command.c **** 	*number = state * sum;
 119:User/Src/command.c **** 	return 1;
 120:User/Src/command.c **** }
