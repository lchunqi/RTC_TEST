  52:User/Src/command.c **** int strSearch(char* source, char* target)
  53:User/Src/command.c **** {
  54:User/Src/command.c **** 	int len_source = strlen(source);
  55:User/Src/command.c **** 	int len_target = strlen(target);
  56:User/Src/command.c **** 	int i, j;
  57:User/Src/command.c **** 	if (len_source < len_target) {
  58:User/Src/command.c **** 		return -1;
  59:User/Src/command.c **** 	}		
  60:User/Src/command.c **** 	for (i = 0; i <= len_source - len_target; i++) {
  61:User/Src/command.c **** 		for (j = 0; j < len_target; j++) {
  62:User/Src/command.c **** 			if (source[i + j] != target[j]) { break;}
  63:User/Src/command.c **** 		}
  64:User/Src/command.c **** 		if (j == len_target) { return i;}
  65:User/Src/command.c **** 	}
  66:User/Src/command.c **** 	return -1;	
  67:User/Src/command.c **** }
