 122:User/Src/command.c **** uint8_t CharToFloat(char* source, uint8_t start, float* number)
 123:User/Src/command.c **** {
 124:User/Src/command.c **** 		uint8_t length;
 125:User/Src/command.c **** 		uint8_t i;
 126:User/Src/command.c **** 		float sum = 0;
 127:User/Src/command.c **** 		int state = 1;
 128:User/Src/command.c **** 		float smallNumber = 0.1;
 129:User/Src/command.c **** 		length = strlen(source);
 130:User/Src/command.c **** 		if (length <= start) {
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccJrI7lo.s 			page 4


 131:User/Src/command.c **** 				*number = 0;
 132:User/Src/command.c **** 				return 0;
 133:User/Src/command.c **** 		}
 134:User/Src/command.c **** 		
 135:User/Src/command.c **** 		if (source[start] == '-') {
 136:User/Src/command.c **** 				state = -1;
 137:User/Src/command.c **** 				start++;
 138:User/Src/command.c **** 		}
 139:User/Src/command.c **** 		for (i = start; i < length; i++){
 140:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 141:User/Src/command.c **** 						sum = sum * 10 + source[i] - '0';
 142:User/Src/command.c **** 				} else if (source[i] == '.') {
 143:User/Src/command.c **** 						i++;
 144:User/Src/command.c **** 						break;
 145:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 146:User/Src/command.c **** 						break;
 147:User/Src/command.c **** 				}	else {
 148:User/Src/command.c **** 						*number = 0;
 149:User/Src/command.c **** 						return 0;
 150:User/Src/command.c **** 				}					
 151:User/Src/command.c **** 		}
 152:User/Src/command.c **** 		for (; i < length; i++) {
 153:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 154:User/Src/command.c **** 						sum += smallNumber * (source[i] - '0');
 155:User/Src/command.c **** 						smallNumber = smallNumber * 0.1;
 156:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 157:User/Src/command.c **** 						break;
 158:User/Src/command.c **** 				}	else {
 159:User/Src/command.c **** 						*number = 0;
 160:User/Src/command.c **** 						return 0;
 161:User/Src/command.c **** 				}	
 162:User/Src/command.c **** 		}
 163:User/Src/command.c **** 		*number = state * sum;
 164:User/Src/command.c **** 		return 1;
 165:User/Src/command.c **** }
