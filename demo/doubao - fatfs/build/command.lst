  53:User/Src/command.c **** int strSearch(char* source, char* target)
  54:User/Src/command.c **** {
  55:User/Src/command.c **** 	int len_source = strlen(source);
  56:User/Src/command.c **** 	int len_target = strlen(target);
  57:User/Src/command.c **** 	int i, j;
  58:User/Src/command.c **** 	if (len_source < len_target) {
  59:User/Src/command.c **** 		return -1;
  60:User/Src/command.c **** 	}		
  61:User/Src/command.c **** 	for (i = 0; i <= len_source - len_target; i++) {
  62:User/Src/command.c **** 		for (j = 0; j < len_target; j++) {
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDI7sOE.s 			page 3


  63:User/Src/command.c **** 			if (source[i + j] != target[j]) { break;}
  64:User/Src/command.c **** 		}
  65:User/Src/command.c **** 		if (j == len_target) { return i;}
  66:User/Src/command.c **** 	}
  67:User/Src/command.c **** 	return -1;	
  68:User/Src/command.c **** }
