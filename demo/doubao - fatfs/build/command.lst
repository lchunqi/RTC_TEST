  70:User/Src/command.c **** uint16_t CharToInt(char* source, uint8_t start, int* number)
  71:User/Src/command.c **** {
  72:User/Src/command.c **** 	uint16_t length;
  73:User/Src/command.c **** 	uint16_t i;
  74:User/Src/command.c **** 	int sum = 0;
  75:User/Src/command.c **** 	int state = 0;
  76:User/Src/command.c **** 	uint8_t hex = 0;
  77:User/Src/command.c **** 	length = strlen(source);
  78:User/Src/command.c **** 	if (start >= length) {
  79:User/Src/command.c **** 		*number = 0;
  80:User/Src/command.c **** 		return 0;
  81:User/Src/command.c **** 	}
  82:User/Src/command.c **** 	if (source[start] == '-') {
  83:User/Src/command.c **** 		state = -1;
  84:User/Src/command.c **** 		start++;
  85:User/Src/command.c **** 	} else {
  86:User/Src/command.c **** 		state = 1;
  87:User/Src/command.c **** 		if (start + 1 < length ) {
  88:User/Src/command.c **** 			if (source[start] == '0' && (source[start + 1] == 'x' ||source[start + 1] == 'X')) {
  89:User/Src/command.c **** 				start += 2;
  90:User/Src/command.c **** 				hex = 1;
  91:User/Src/command.c **** 			}
  92:User/Src/command.c **** 		}
  93:User/Src/command.c **** 	}
  94:User/Src/command.c **** 	for (i = start; i < length; i++) {
  95:User/Src/command.c **** 		if (source[i] >= '0' && source[i] <= '9') {
  96:User/Src/command.c **** 			if (hex == 1) {
  97:User/Src/command.c **** 				sum = sum * 16 + source[i] - '0';
  98:User/Src/command.c **** 			} else {
  99:User/Src/command.c **** 				sum = sum * 10 + source[i] - '0';
 100:User/Src/command.c **** 			}
 101:User/Src/command.c **** 		} else if (source[i] >= 'a' && source[i] <= 'f') {
 102:User/Src/command.c **** 			if (hex == 1) {
 103:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'a' + 10;
 104:User/Src/command.c **** 			} else {
 105:User/Src/command.c **** 				*number = 0;
 106:User/Src/command.c **** 				return 0;
 107:User/Src/command.c **** 			}
 108:User/Src/command.c **** 		}else if (source[i] >= 'A' && source[i] <= 'F') {
 109:User/Src/command.c **** 			if (hex == 1) {
 110:User/Src/command.c **** 				sum = sum * 16  + source[i] - 'A' + 10;
 111:User/Src/command.c **** 			} else {
 112:User/Src/command.c **** 				*number = 0;
 113:User/Src/command.c **** 				return 0;
 114:User/Src/command.c **** 			}
 115:User/Src/command.c **** 		} else if (source[i] == ' ' || source[i] == ',') {
 116:User/Src/command.c **** 			break;
 117:User/Src/command.c **** 		}
 118:User/Src/command.c **** 	}
 119:User/Src/command.c **** 	*number = state * sum;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccDI7sOE.s 			page 4


 120:User/Src/command.c **** 	return 1;
 121:User/Src/command.c **** }
 122:User/Src/command.c **** 
 123:User/Src/command.c **** uint8_t CharToFloat(char* source, uint8_t start, float* number)
 124:User/Src/command.c **** {
 125:User/Src/command.c **** 		uint8_t length;
 126:User/Src/command.c **** 		uint8_t i;
 127:User/Src/command.c **** 		float sum = 0;
 128:User/Src/command.c **** 		int state = 1;
 129:User/Src/command.c **** 		float smallNumber = 0.1;
 130:User/Src/command.c **** 		length = strlen(source);
 131:User/Src/command.c **** 		if (length <= start) {
 132:User/Src/command.c **** 				*number = 0;
 133:User/Src/command.c **** 				return 0;
 134:User/Src/command.c **** 		}
 135:User/Src/command.c **** 		
 136:User/Src/command.c **** 		if (source[start] == '-') {
 137:User/Src/command.c **** 				state = -1;
 138:User/Src/command.c **** 				start++;
 139:User/Src/command.c **** 		}
 140:User/Src/command.c **** 		for (i = start; i < length; i++){
 141:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 142:User/Src/command.c **** 						sum = sum * 10 + source[i] - '0';
 143:User/Src/command.c **** 				} else if (source[i] == '.') {
 144:User/Src/command.c **** 						i++;
 145:User/Src/command.c **** 						break;
 146:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 147:User/Src/command.c **** 						break;
 148:User/Src/command.c **** 				}	else {
 149:User/Src/command.c **** 						*number = 0;
 150:User/Src/command.c **** 						return 0;
 151:User/Src/command.c **** 				}					
 152:User/Src/command.c **** 		}
 153:User/Src/command.c **** 		for (; i < length; i++) {
 154:User/Src/command.c **** 				if (source[i] >= '0' && source[i] <= '9') {
 155:User/Src/command.c **** 						sum += smallNumber * (source[i] - '0');
 156:User/Src/command.c **** 						smallNumber = smallNumber * 0.1;
 157:User/Src/command.c **** 				} else if (source[i] == ' ' || source[i] == ',') {
 158:User/Src/command.c **** 						break;
 159:User/Src/command.c **** 				}	else {
 160:User/Src/command.c **** 						*number = 0;
 161:User/Src/command.c **** 						return 0;
 162:User/Src/command.c **** 				}	
 163:User/Src/command.c **** 		}
 164:User/Src/command.c **** 		*number = state * sum;
 165:User/Src/command.c **** 		return 1;
 166:User/Src/command.c **** }
