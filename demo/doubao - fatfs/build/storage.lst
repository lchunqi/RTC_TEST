  33:User/Src/storage.c **** /************************** 存储系统核心模块（初始化/格式化） **************************/
  34:User/Src/storage.c **** // 修改storage.c中的Storage_Init函数
  35:User/Src/storage.c **** StorageError Storage_Init(void) {
  36:User/Src/storage.c ****     FRESULT res = FR_OK;
  37:User/Src/storage.c ****     Storage_print("存储初始化: 开始挂载FatFs文件系统...\n");
  38:User/Src/storage.c ****     // 先尝试挂载现有文件系统
  39:User/Src/storage.c ****     res = f_mount(&fs, "", 1);
  40:User/Src/storage.c ****     if (res == FR_OK) {
  41:User/Src/storage.c ****         Storage_print("存储初始化: 成功挂载现有文件系统！\n");
  42:User/Src/storage.c ****         return STORAGE_OK;
  43:User/Src/storage.c ****     } else if (res == FR_NO_FILESYSTEM) {
  44:User/Src/storage.c ****         Storage_print("存储初始化: 未检测到文件系统，创建新文件系统...\n");
  45:User/Src/storage.c ****         // 首次上电无文件系统时创建
  46:User/Src/storage.c ****         if (Storage_Format() != STORAGE_OK) {
  47:User/Src/storage.c ****             Storage_print("存储初始化: 格式化失败！\n");
  48:User/Src/storage.c ****             return STORAGE_ERROR_INIT;
  49:User/Src/storage.c ****         }
  50:User/Src/storage.c ****         res = f_mount(&fs, "", 1);
  51:User/Src/storage.c ****         if (res == FR_OK) {
  52:User/Src/storage.c ****             Storage_print("存储初始化: 新文件系统创建并挂载成功！\n");
  53:User/Src/storage.c ****             return STORAGE_OK;
  54:User/Src/storage.c ****         }
  55:User/Src/storage.c ****     } else {
  56:User/Src/storage.c ****         Storage_print("存储初始化: 挂载失败，尝试修复文件系统...\n");
  57:User/Src/storage.c ****         // 其他错误（如元数据损坏），尝试修复
  58:User/Src/storage.c ****         if (Storage_Format() != STORAGE_OK) {
  59:User/Src/storage.c ****             Storage_print("存储初始化: 修复失败！\n");
  60:User/Src/storage.c ****             return STORAGE_ERROR_INIT;
  61:User/Src/storage.c ****         }
  62:User/Src/storage.c ****         res = f_mount(&fs, "", 1);
  63:User/Src/storage.c ****         if (res == FR_OK) {
  64:User/Src/storage.c ****             Storage_print("存储初始化: 文件系统修复并挂载成功！\n");
  65:User/Src/storage.c ****             return STORAGE_OK;
  66:User/Src/storage.c ****         }
  67:User/Src/storage.c ****     }
  68:User/Src/storage.c **** 
  69:User/Src/storage.c ****     Storage_print("存储初始化: 挂载最终失败，错误码%u\n", res);
  70:User/Src/storage.c ****     return STORAGE_ERROR_INIT;
  71:User/Src/storage.c **** }
