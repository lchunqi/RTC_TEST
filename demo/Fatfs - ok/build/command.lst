  69:User/Src/command.c **** uint16_t CharToInt(char* source, uint8_t start, int* number)
  70:User/Src/command.c **** {
  71:User/Src/command.c ****     uint16_t length = strlen(source);
  72:User/Src/command.c ****     uint16_t i;
  73:User/Src/command.c ****     int sum = 0;
  74:User/Src/command.c ****     int state = 1;
  75:User/Src/command.c ****     uint8_t hex = 0;
  76:User/Src/command.c **** 
  77:User/Src/command.c ****     *number = 0;
  78:User/Src/command.c ****     if (start >= length) return 0;
  79:User/Src/command.c **** 
  80:User/Src/command.c ****     if (source[start] == '-')
  81:User/Src/command.c ****     {
  82:User/Src/command.c ****         state = -1;
  83:User/Src/command.c ****         start++;
  84:User/Src/command.c ****     }
  85:User/Src/command.c **** 
  86:User/Src/command.c ****     if (start + 1 < length)
  87:User/Src/command.c ****     {
  88:User/Src/command.c ****         if (source[start] == '0' && (source[start + 1] == 'x' || source[start + 1] == 'X'))
ARM GAS  C:\Users\84759\AppData\Local\Temp\cc7RoKct.s 			page 3


  89:User/Src/command.c ****         {
  90:User/Src/command.c ****             start += 2;
  91:User/Src/command.c ****             hex = 1;
  92:User/Src/command.c ****         }
  93:User/Src/command.c ****     }
  94:User/Src/command.c **** 
  95:User/Src/command.c ****     for (i = start; i < length; i++)
  96:User/Src/command.c ****     {
  97:User/Src/command.c ****         if (source[i] >= '0' && source[i] <= '9')
  98:User/Src/command.c ****         {
  99:User/Src/command.c ****             sum = hex ? (sum * 16 + (source[i] - '0')) : (sum * 10 + (source[i] - '0'));
 100:User/Src/command.c ****         }
 101:User/Src/command.c ****         else if (source[i] >= 'a' && source[i] <= 'f')
 102:User/Src/command.c ****         {
 103:User/Src/command.c ****             if (!hex) return 0;
 104:User/Src/command.c ****             sum = sum * 16 + (source[i] - 'a' + 10);
 105:User/Src/command.c ****         }
 106:User/Src/command.c ****         else if (source[i] >= 'A' && source[i] <= 'F')
 107:User/Src/command.c ****         {
 108:User/Src/command.c ****             if (!hex) return 0;
 109:User/Src/command.c ****             sum = sum * 16 + (source[i] - 'A' + 10);
 110:User/Src/command.c ****         }
 111:User/Src/command.c ****         else if (source[i] == ' ' || source[i] == ',')
 112:User/Src/command.c ****         {
 113:User/Src/command.c ****             break;
 114:User/Src/command.c ****         }
 115:User/Src/command.c ****         else
 116:User/Src/command.c ****         {
 117:User/Src/command.c ****             return 0;
 118:User/Src/command.c ****         }
 119:User/Src/command.c ****     }
 120:User/Src/command.c **** 
 121:User/Src/command.c ****     *number = state * sum;
 122:User/Src/command.c ****     return 1;
 123:User/Src/command.c **** }
