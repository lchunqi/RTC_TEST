  47:User/Src/command.c **** int  strSearch(const char* source, const char* target)
  48:User/Src/command.c **** {
  49:User/Src/command.c ****     int len_source = strlen(source);
  50:User/Src/command.c ****     int len_target = strlen(target);
  51:User/Src/command.c ****     int i, j;
  52:User/Src/command.c **** 
  53:User/Src/command.c ****     if (len_source < len_target || len_target == 0)
  54:User/Src/command.c ****         return -1;
  55:User/Src/command.c **** 
  56:User/Src/command.c ****     for (i = 0; i <= len_source - len_target; i++)
  57:User/Src/command.c ****     {
  58:User/Src/command.c ****         for (j = 0; j < len_target; j++)
  59:User/Src/command.c ****         {
  60:User/Src/command.c ****             if (source[i + j] != target[j])
  61:User/Src/command.c ****                 break;
  62:User/Src/command.c ****         }
  63:User/Src/command.c ****         if (j == len_target)
  64:User/Src/command.c ****             return i;
  65:User/Src/command.c ****     }
  66:User/Src/command.c ****     return -1;
  67:User/Src/command.c **** }
