 160:User/Src/multi_button.c **** /**
 161:User/Src/multi_button.c ****   * @brief  Start the button work, add the handle into work list.
 162:User/Src/multi_button.c ****   * @param  handle: target handle struct.
 163:User/Src/multi_button.c ****   * @retval 0: succeed. -1: already exist.
 164:User/Src/multi_button.c ****   */
 165:User/Src/multi_button.c **** int button_start(struct Button* handle)
 166:User/Src/multi_button.c **** {
 167:User/Src/multi_button.c **** 	struct Button* target = head_handle;
 168:User/Src/multi_button.c **** 	while(target) {
 169:User/Src/multi_button.c **** 		if(target == handle) return -1;	//already exist.
 170:User/Src/multi_button.c **** 		target = target->next;
 171:User/Src/multi_button.c **** 	}
 172:User/Src/multi_button.c **** 	handle->next = head_handle;
 173:User/Src/multi_button.c **** 	head_handle = handle;
 174:User/Src/multi_button.c **** 	return 0;
 175:User/Src/multi_button.c **** }
 176:User/Src/multi_button.c **** 
 177:User/Src/multi_button.c **** /**
 178:User/Src/multi_button.c ****   * @brief  Stop the button work, remove the handle off work list.
 179:User/Src/multi_button.c ****   * @param  handle: target handle struct.
 180:User/Src/multi_button.c ****   * @retval None
 181:User/Src/multi_button.c ****   */
 182:User/Src/multi_button.c **** void button_stop(struct Button* handle)
 183:User/Src/multi_button.c **** {
 184:User/Src/multi_button.c **** 	struct Button** curr;
 185:User/Src/multi_button.c **** 	for(curr = &head_handle; *curr; ) {
 186:User/Src/multi_button.c **** 		struct Button* entry = *curr;
 187:User/Src/multi_button.c **** 		if(entry == handle) {
 188:User/Src/multi_button.c **** 			*curr = entry->next;
 189:User/Src/multi_button.c **** //			free(entry);
 190:User/Src/multi_button.c **** 			return;//glacier add 2021-8-18
 191:User/Src/multi_button.c **** 		} else {
 192:User/Src/multi_button.c **** 			curr = &entry->next;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccn2r85U.s 			page 13


 193:User/Src/multi_button.c **** 		}
 194:User/Src/multi_button.c **** 	}
 195:User/Src/multi_button.c **** }
 196:User/Src/multi_button.c **** 
 197:User/Src/multi_button.c **** /**
 198:User/Src/multi_button.c ****   * @brief  background ticks, timer repeat invoking interval 5ms.
 199:User/Src/multi_button.c ****   * @param  None.
 200:User/Src/multi_button.c ****   * @retval None
 201:User/Src/multi_button.c ****   */
 202:User/Src/multi_button.c **** void button_ticks(void)
 203:User/Src/multi_button.c **** {
 204:User/Src/multi_button.c **** 	struct Button* target;
 205:User/Src/multi_button.c **** 	for(target=head_handle; target; target=target->next) {
 206:User/Src/multi_button.c **** 		button_handler(target);
 207:User/Src/multi_button.c **** 	}
 208:User/Src/multi_button.c **** 		
 209:User/Src/multi_button.c **** }
