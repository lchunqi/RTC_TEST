  16:User/Src/multi_button.c **** /**
  17:User/Src/multi_button.c ****   * @brief  Initializes the button struct handle.
  18:User/Src/multi_button.c ****   * @param  handle: the button handle struct.
  19:User/Src/multi_button.c ****   * @param  pin_level: read the HAL GPIO of the connected button level.
  20:User/Src/multi_button.c ****   * @param  active_level: pressed GPIO level.
  21:User/Src/multi_button.c ****   * @param  button_id: the button id.
  22:User/Src/multi_button.c ****   * @retval None
  23:User/Src/multi_button.c ****   */
  24:User/Src/multi_button.c **** void button_init(struct Button* handle, uint8_t(*pin_level)(uint8_t), uint8_t active_level, uint8_t
  25:User/Src/multi_button.c **** {
  26:User/Src/multi_button.c **** 	memset(handle, 0, sizeof(struct Button));
  27:User/Src/multi_button.c **** 	handle->event = (uint8_t)NONE_PRESS;
  28:User/Src/multi_button.c **** 	handle->hal_button_Level = pin_level;
  29:User/Src/multi_button.c **** 	handle->button_level = !active_level;
  30:User/Src/multi_button.c **** 	handle->active_level = active_level;
  31:User/Src/multi_button.c **** 	handle->button_id = button_id;
  32:User/Src/multi_button.c **** }
