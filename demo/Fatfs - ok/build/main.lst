 211:Core/Src/main.c **** void UsbPrintf(char* fmt,...)  
 212:Core/Src/main.c **** {  
 213:Core/Src/main.c **** 	va_list ap;
 214:Core/Src/main.c **** 	memset(g_UsbTxBuff, 0, UART_TRANSMIT_BUFF_NUMBER);
 215:Core/Src/main.c **** 	va_start(ap, fmt);
 216:Core/Src/main.c **** 	vsnprintf((char*)g_UsbTxBuff, UART_TRANSMIT_BUFF_NUMBER, fmt, ap);
 217:Core/Src/main.c **** 	va_end(ap);
 218:Core/Src/main.c **** 	HAL_UART_Transmit(&huart1, g_UsbTxBuff, strlen((char*)g_UsbTxBuff), 1000);
 219:Core/Src/main.c **** }
