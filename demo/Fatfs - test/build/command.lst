 125:User/Src/command.c **** uint8_t CharToFloat(char* source, uint8_t start, float* number)
 126:User/Src/command.c **** {
 127:User/Src/command.c ****     uint8_t length = strlen(source);
 128:User/Src/command.c ****     uint8_t i;
 129:User/Src/command.c ****     float sum = 0;
 130:User/Src/command.c ****     int state = 1;
 131:User/Src/command.c ****     float small_num = 0.1f;
 132:User/Src/command.c **** 
 133:User/Src/command.c ****     *number = 0.0f;
 134:User/Src/command.c ****     if (length <= start) return 0;
 135:User/Src/command.c **** 
 136:User/Src/command.c ****     if (source[start] == '-')
 137:User/Src/command.c ****     {
 138:User/Src/command.c ****         state = -1;
 139:User/Src/command.c ****         start++;
 140:User/Src/command.c ****     }
 141:User/Src/command.c **** 
 142:User/Src/command.c ****     for (i = start; i < length; i++)
 143:User/Src/command.c ****     {
 144:User/Src/command.c ****         if (source[i] >= '0' && source[i] <= '9')
 145:User/Src/command.c ****         {
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccVSdzbq.s 			page 4


 146:User/Src/command.c ****             sum = sum * 10 + (source[i] - '0');
 147:User/Src/command.c ****         }
 148:User/Src/command.c ****         else if (source[i] == '.')
 149:User/Src/command.c ****         {
 150:User/Src/command.c ****             i++;
 151:User/Src/command.c ****             break;
 152:User/Src/command.c ****         }
 153:User/Src/command.c ****         else if (source[i] == ' ' || source[i] == ',')
 154:User/Src/command.c ****         {
 155:User/Src/command.c ****             break;
 156:User/Src/command.c ****         }
 157:User/Src/command.c ****         else
 158:User/Src/command.c ****         {
 159:User/Src/command.c ****             return 0;
 160:User/Src/command.c ****         }
 161:User/Src/command.c ****     }
 162:User/Src/command.c **** 
 163:User/Src/command.c ****     for (; i < length; i++)
 164:User/Src/command.c ****     {
 165:User/Src/command.c ****         if (source[i] >= '0' && source[i] <= '9')
 166:User/Src/command.c ****         {
 167:User/Src/command.c ****             sum += small_num * (source[i] - '0');
 168:User/Src/command.c ****             small_num *= 0.1f;
 169:User/Src/command.c ****         }
 170:User/Src/command.c ****         else if (source[i] == ' ' || source[i] == ',')
 171:User/Src/command.c ****         {
 172:User/Src/command.c ****             break;
 173:User/Src/command.c ****         }
 174:User/Src/command.c ****         else
 175:User/Src/command.c ****         {
 176:User/Src/command.c ****             return 0;
 177:User/Src/command.c ****         }
 178:User/Src/command.c ****     }
 179:User/Src/command.c **** 
 180:User/Src/command.c ****     *number = state * sum;
 181:User/Src/command.c ****     return 1;
 182:User/Src/command.c **** }
