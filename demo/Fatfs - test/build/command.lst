 184:User/Src/command.c **** uint8_t Data_copy_from_pos(char *dest, const char *src, uint16_t start_pos, uint16_t copy_len)
 185:User/Src/command.c **** {
 186:User/Src/command.c ****     if (dest == NULL || src == NULL)
 187:User/Src/command.c ****     {
 188:User/Src/command.c ****         UsbPrintf("[command] error: pointer null !\r\n");
 189:User/Src/command.c ****         return 0;
 190:User/Src/command.c ****     }
 191:User/Src/command.c **** 
 192:User/Src/command.c ****     int src_len = strlen(src);
 193:User/Src/command.c ****     if (start_pos < 0 || start_pos >= src_len)
 194:User/Src/command.c ****     {
 195:User/Src/command.c ****         UsbPrintf("[command] error: start pos invalid !\r\n");
 196:User/Src/command.c ****         return 0;
 197:User/Src/command.c ****     }
 198:User/Src/command.c **** 
 199:User/Src/command.c ****     if (copy_len < 0 || (start_pos + copy_len) > src_len)
 200:User/Src/command.c ****     {
 201:User/Src/command.c ****         UsbPrintf("[command] error: copy len invalid !\r\n");
 202:User/Src/command.c ****         return 0;
ARM GAS  C:\Users\84759\AppData\Local\Temp\ccVSdzbq.s 			page 5


 203:User/Src/command.c ****     }
 204:User/Src/command.c **** 
 205:User/Src/command.c ****     memcpy(dest, src + start_pos, copy_len);
 206:User/Src/command.c ****     dest[copy_len] = '\0';
 207:User/Src/command.c ****     return 1;
 208:User/Src/command.c **** }
